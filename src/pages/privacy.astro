---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Privacy Policy - Nirvee Visa Immigration Consultants" description="Nirvee Visa privacy policy. Learn how we protect your personal information & immigration data. GDPR compliant data handling practices for visa applicants." noindex={true}>
  <section class="legal-section section-padding">
    <div class="container narrow-container">
      <h1>Privacy Policy</h1>
      <p class="updated">Last Updated: April 2, 2026</p>
      
      <div class="content">
        <p>At Nirvee Visa, we are committed to protecting your privacy. This policy explains how we collect and use your data.</p>
        
        <h2>1. Information We Collect</h2>
        <p>We collect information you provide directly to us through our eligibility assessment, contact forms, and newsletter subscription.</p>
        
        <h2>2. How We Use Information</h2>
        <p>Your data is used solely for the purpose of providing immigration consultancy services and communicating with you about your case.</p>
        
        <h2>3. Data Protection</h2>
        <p>We implement strict security measures to protect your personal information from unauthorized access or disclosure.</p>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .legal-section h1 { margin-bottom: 10px; font-weight: 800; color: var(--text-main); padding-top: 120px; }
  .updated { color: var(--text-muted); font-size: 0.9rem; margin-bottom: 40px; }
  .narrow-container { max-width: 800px; }
  .content h2 { margin: 30px 0 15px; font-size: 1.5rem; color: var(--primary-purple); }
  .content p { margin-bottom: 20px; color: var(--text-muted); }

  @media (max-width: 768px) {
    .legal-section h1 {
      padding-top: 100px;
      font-size: 1.75rem;
    }
    .content h2 {
      font-size: 1.3rem;
    }
    .section-padding {
      padding: 50px 0;
    }
  }

  @media (max-width: 480px) {
    .legal-section h1 {
      padding-top: 80px;
      font-size: 1.5rem;
    }
    .content h2 {
      font-size: 1.2rem;
      margin: 24px 0 12px;
    }
    .content p {
      font-size: 0.95rem;
    }
    .updated {
      font-size: 0.85rem;
    }
    .narrow-container {
      padding: 0 16px;
    }
  }
</style>
