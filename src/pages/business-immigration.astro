---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout 
  title="Business Immigration Pathways" 
  description="Business immigration programs for entrepreneurs and investors"
>
  <!-- Page Header -->
  <section class="page-header section-padding">
    <div class="container text-center">
      <span class="gold-text uppercase-label">Visa Services</span>
      <h1>Business Immigration Pathways</h1>
      <p class="subtitle">
        Programs for entrepreneurs, investors, and self-employed individuals to establish or expand their business in Canada.
      </p>
    </div>
  </section>

  <!-- Content Section -->
  <section class="visitor-visa-content section-padding">
    <div class="container">
      <div class="content-grid">

        <!-- Provincial Nominee -->
        <div class="glass-card content-section">
          <div class="section-icon">location_city</div>
          <h2>Provincial Nominee Entrepreneur Programs</h2>

          <p>
            Provinces offer streams for entrepreneurs willing to invest, establish, or operate businesses locally.
          </p>

          <div class="highlight-box">
            <h3>Key Benefits:</h3>
            <ul>
              <li>Pathway to permanent residence</li>
              <li>Province-specific business opportunities</li>
              <li>Flexible investment options</li>
            </ul>
          </div>

          <p><em>Contact us for more information regarding other countries.</em></p>
        </div>

        <!-- Start-Up Visa -->
        <div class="glass-card content-section">
          <div class="section-icon">lightbulb</div>
          <h2>Federal Start-Up Visa</h2>

          <p>
            Designed for innovative entrepreneurs supported by investors or venture capital funds.
          </p>

          <div class="highlight-box">
            <h3>Requirements:</h3>
            <ul>
              <li>Investment from approved organizations</li>
              <li>Language proficiency</li>
              <li>Business innovation and scalability</li>
            </ul>
          </div>
        </div>

        <!-- Self Employed -->
        <div class="glass-card content-section">
          <div class="section-icon">brush</div>
          <h2>Self-Employed Persons Program</h2>

          <p>
            Ideal for individuals contributing to cultural or athletic sectors in Canada.
          </p>

          <div class="highlight-box">
            <h3>Evaluation Criteria:</h3>
            <ul>
              <li>Education and experience</li>
              <li>Language skills</li>
              <li>Minimum 35/100 points</li>
            </ul>
          </div>
        </div>

        <!-- Intra Company -->
        <div class="glass-card content-section">
          <div class="section-icon">business_center</div>
          <h2>Intra-Company Transfers</h2>

          <p>
            Allows companies to transfer employees to Canadian branches.
          </p>

          <div class="highlight-box">
            <h3>Eligibility:</h3>
            <ul>
              <li>Company operational for 1+ year</li>
              <li>Senior or specialized roles</li>
              <li>Valid business expansion plan</li>
            </ul>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section section-padding bg-darker">
    <div class="container text-center">
      <h2>Need Help?</h2>
      <p class="subtitle">Our immigration experts are ready to guide you.</p>
      <div class="cta-buttons">
        <a href="/contact" class="btn btn-primary">Contact Us Today</a>
      </div>
    </div>
  </section>

</MainLayout>

<style>
  /* Body Background */
  :global(body) {
    background: linear-gradient(135deg, #faf8ff 0%, #f5f0ff 50%, #fdf2f8 100%);
    min-height: 100vh;
  }

  /* Header */
  .page-header {
    background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), 
                url('/business-immigration.webp') center/cover no-repeat;
    border-bottom: 1px solid var(--border-light);
    padding-top: 150px;
    padding-bottom: 80px;
  }

  .page-header h1,
  .uppercase-label,
  .subtitle {
    color: white;
  }

  /* Layout */
  .content-grid {
    display: grid;
    gap: 40px;
    max-width: 900px;
    margin: 0 auto;
  }

  /* Cards */
  .content-section {
    padding: 40px;
    border-radius: 16px;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    box-shadow: var(--card-shadow);
    position: relative;
    overflow: hidden;
  }

  .content-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.03), rgba(219, 39, 119, 0.03));
    z-index: -1;
  }

  /* Icons */
  .section-icon {
    font-size: 2.5rem;
    margin-bottom: 24px;
    color: var(--primary-purple);
    font-family: 'Material Icons';
  }

  /* Text */
  .content-section h2 {
    font-size: 2rem;
    margin-bottom: 20px;
    color: var(--text-main);
  }

  .content-section p {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 24px;
  }

  /* Highlight box */
  .highlight-box {
    background: rgba(124, 58, 237, 0.05);
    border: 1px solid rgba(124, 58, 237, 0.1);
    border-radius: 12px;
    padding: 24px;
    margin-top: 24px;
  }

  .highlight-box h3 {
    color: var(--primary-purple);
    margin-bottom: 16px;
  }

  .highlight-box li {
    position: relative;
    padding-left: 24px;
    margin-bottom: 12px;
    list-style: none;
  }

  .highlight-box li::before {
    content: 'check_circle';
    position: absolute;
    left: 0;
    color: var(--primary-purple);
    font-family: 'Material Icons';
  }

  /* CTA */
  .bg-darker {
    background-color: var(--background);
    border-top: 1px solid var(--border-light);
  }

  .cta-buttons {
    margin-top: 30px;
  }

  .btn-primary {
    background: var(--primary-gradient);
    color: white;
    padding: 14px 28px;
    border-radius: 8px;
    text-decoration: none;
  }

  /* Responsive */
  @media (max-width: 992px) {
    .page-header {
      padding-top: 120px;
      padding-bottom: 70px;
    }
    .content-section {
      padding: 32px;
    }
    .content-section h2 {
      font-size: 1.8rem;
    }
    .section-icon {
      font-size: 2rem;
    }
    .content-section p {
      font-size: 1rem;
    }
  }

  @media (max-width: 768px) {
    .page-header {
      padding-top: 100px;
      padding-bottom: 60px;
    }
    .page-header h1 {
      font-size: 1.75rem;
    }
    .subtitle {
      font-size: 1rem;
    }
    .content-grid {
      gap: 24px;
    }
    .content-section {
      padding: 24px;
      border-radius: 12px;
    }
    .content-section h2 {
      font-size: 1.5rem;
      margin-bottom: 16px;
    }
    .section-icon {
      font-size: 1.75rem;
      margin-bottom: 16px;
    }
    .content-section p {
      font-size: 0.95rem;
      margin-bottom: 16px;
    }
    .content-section li {
      font-size: 0.9rem;
    }
    .highlight-box {
      padding: 16px;
    }
    .highlight-box h3 {
      font-size: 1.1rem;
    }
    .highlight-box li {
      font-size: 0.9rem;
    }
    .cta-buttons {
      flex-direction: column;
      align-items: center;
      gap: 12px;
    }
    .btn-primary {
      width: 100%;
      max-width: 280px;
      text-align: center;
    }
  }

  @media (max-width: 480px) {
    .page-header {
      padding-top: 80px;
      padding-bottom: 50px;
    }
    .page-header h1 {
      font-size: 1.5rem;
    }
    .subtitle {
      font-size: 0.9rem;
    }
    .content-section {
      padding: 20px;
    }
    .content-section h2 {
      font-size: 1.3rem;
    }
    .highlight-box {
      padding: 14px;
    }
    .btn-primary {
      padding: 12px 24px;
      font-size: 0.95rem;
    }
  }
</style>