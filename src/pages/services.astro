---
import MainLayout from '../layouts/MainLayout.astro';

const services = [
  {
    icon: 'flight_takeoff',
    title: "VISITOR VISA",
    description: 'Complete guidance for temporary travel to Canada, including visa applications and electronic Travel Authorization (eTA) services.',
    link: '/visitor-visa',
    backgroundImage: '/visitor-vissa.jpg'
  },
  {
    icon: 'school',
    title: 'STUDY PERMIT',
    description: 'Complete guidance for international students to obtain study permits, including application support and understanding visa requirements.',
    link: '/study-permit',
    backgroundImage: '/student.jpg'
  },
  {
    icon: 'work',
    title: 'WORK VISA',
    description: 'Comprehensive support for various work permits, including employer-specific, open work permits, and Post-Graduation Work Permits (PGWP).',
    link: '/work-visa',
    backgroundImage: '/Work-Visa.jpg'
  },
  {
    icon: 'family_restroom',
    title: 'FAMILY SPONSORSHIP',
    description: 'Guidance for sponsoring spouses, partners, dependent children, and parents/grandparents through Super Visa and other family reunification programs.',
    link: '/family-sponsorship',
    backgroundImage: '/family.png'
  },
  {
    icon: 'business_center',
    title: 'BUSINESS IMMIGRATION PATHWAYS',
    description: 'Guidance for entrepreneurs, investors, and self-employed individuals to grow their business in Canada.',
    link: '/business-immigration',
    backgroundImage: '/business-immigration.jpg'
  },
  {
    icon: 'verified_user',
    title: 'PERMANENT RESIDENCY OPTIONS',
    description: 'Pathways to Canadian permanent residency via family, economic, and provincial programs.',
    link: '/permanent-residency',
    backgroundImage: '/permanent.png'
  }
];
---

<MainLayout title="Capabilities" description="Premium corporate and individual immigration capabilities.">
  <section class="page-header section-padding">
    <div class="container text-center">
      <span class="gold-text uppercase-label">Our Capabilities</span>
      <h1>Immigration Services</h1>
      <p class="subtitle">We deliver white-glove, end-to-end immigration strategies tailored for elite professionals, investors, and elite corporations.</p>
    </div>
  </section>

  <section class="services-list section-padding">
    <div class="container">
      <div class="grid services-grid">
        {services.map(service => (
          <a href={service.link || '#'} class="service-link">
            <div class="glass-card service-card" style={`background-image: url('${service.backgroundImage}')`}>
              <div class="dark-overlay"></div>
              <div class="card-content">
                <div class="icon-wrapper">
                  <span class="material-icons">{service.icon}</span>
                </div>
                <h3>{service.title}</h3>
                <p>{service.description}</p>
                {service.link && (
                  <div class="card-arrow">
                    <span class="material-icons">arrow_forward</span>
                  </div>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="process section-padding bg-darker">
    <div class="container">
      <h2 class="text-center">The Nirvee Visa Methodology</h2>
      <p class="text-center subtitle mb-60">A proprietary four-phase framework ensuring unparalleled precision.</p>
      
      <div class="process-grid">
        <div class="process-step">
          <div class="step-num">01</div>
          <h3>Strategic Consultation</h3>
          <p>Initial executive assessment aligning your global mobility ambitions with legislative realities.</p>
        </div>
        <div class="process-step">
          <div class="step-num">02</div>
          <h3>Blueprint Creation</h3>
          <p>Developing a bespoke, risk-mitigated roadmap for your specific jurisdictional target.</p>
        </div>
        <div class="process-step">
          <div class="step-num">03</div>
          <h3>Rigorous Audit</h3>
          <p>Meticulous documentation compilation and preemptive legal stress-testing of your portfolio.</p>
        </div>
        <div class="process-step">
          <div class="step-num">04</div>
          <h3>Execution & Grant</h3>
          <p>Seamless liaison with government bodies to secure a rapid and unencumbered approval.</p>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .page-header {
    background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url('/services-header.jpg') center/cover no-repeat;
    border-bottom: 1px solid var(--border-light);
    padding-top: 150px;
    padding-bottom: 80px;
  }

  .page-header h1 {
    color: white;
  }

  .uppercase-label {
    display: inline-block;
    font-family: var(--font-heading);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 16px;
    font-size: 0.9rem;
    color: white;
  }

  .subtitle {
    margin-top: 20px;
    font-size: 1.25rem;
    color: white;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }
  
  .mb-60 { margin-bottom: 60px; }

  .services-grid {
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 40px;
  }

  .service-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 32px;
    border-radius: 16px;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    box-shadow: var(--card-shadow);
    background-size: cover;
    background-position: center;
    min-height: 280px;
  }

  .dark-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1;
    transition: background 0.4s ease;
  }

  .card-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .service-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(124, 58, 237, 0.25);
    border-color: var(--primary-pink);
  }

  .service-card:hover .dark-overlay {
    background: rgba(0, 0, 0, 0.7);
  }

  .icon-wrapper {
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.2), rgba(219, 39, 119, 0.15));
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    margin-bottom: 24px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    transition: all 0.3s ease;
    position: relative;
  }

  .icon-wrapper .material-icons {
    font-size: 2rem;
    color: white;
  }

  .icon-wrapper::after {
    content: '';
    position: absolute;
    top: -2px;
    left: -2px;
    right: -2px;
    bottom: -2px;
    background: var(--primary-gradient);
    border-radius: 12px;
    opacity: 0;
    z-index: -1;
    transition: opacity 0.3s ease;
  }

  .service-card:hover .icon-wrapper {
    transform: scale(1.1) rotate(5deg);
    box-shadow: 0 8px 25px rgba(124, 58, 237, 0.25);
  }

  .service-card:hover .icon-wrapper::after {
    opacity: 1;
  }

  .service-card h3 {
    margin-bottom: 16px;
    font-size: 1.5rem;
    font-weight: 600;
    transition: all 0.3s ease;
    color: white;
  }

  .service-card p {
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.6;
    margin-bottom: 0;
    transition: all 0.3s ease;
  }

  .service-card:hover h3 {
    color: white;
    transform: translateX(4px);
  }

  .service-card:hover p {
    color: rgba(255, 255, 255, 1);
  }

  .service-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .card-arrow {
    position: absolute;
    bottom: 10px;
    right: 24px;
    color: white;
    opacity: 0;
    transform: translateX(-10px);
    transition: all 0.3s ease;
  }

  .card-arrow .material-icons {
    font-size: 1.5rem;
  }

  .service-card:hover .card-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .bg-darker {
    background-color: var(--background);
    border-top: 1px solid var(--border-light);
  }

  .process-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 40px;
    position: relative;
  }

  .process-step {
    text-align: left;
    position: relative;
    padding: 30px;
    background: linear-gradient(135deg, #faf8ff 0%, #f5f0ff 100%);
    border-radius: 12px;
    border: 1px solid #e8e0f5;
    transition: var(--transition);
    box-shadow: 0 4px 20px rgba(139, 92, 246, 0.08);
  }

  .process-step:hover {
    border-color: var(--primary-purple);
    transform: translateY(-5px);
  }

  .step-num {
    font-family: var(--font-heading);
    font-size: 3rem;
    font-weight: 800;
    color: var(--primary-purple);
    opacity: 0.1;
    line-height: 1;
    margin-bottom: 20px;
  }

  .process-step h3 {
    font-size: 1.3rem;
    margin-bottom: 16px;
  }

  .process-step p {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    .page-header { padding-top: 100px; }
    .process-grid { grid-template-columns: 1fr; }
  }
</style>