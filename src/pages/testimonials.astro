---
import MainLayout from '../layouts/MainLayout.astro';
import TestimonialCard from '../components/TestimonialCard.astro';

const testimonials = [
  {
    name: 'James Wilson',
    role: 'Corporate Executive Route',
    content: 'The senior strategists at Nirvee Visa navigated my complex intra-company transfer with absolute precision. Their attention to detail in document preparation was the key to an expedited process.',
    image: '👨‍💼'
  },
  {
    name: 'Priya Sharma',
    role: 'Global Talent Visa',
    content: 'Unparalleled professionalism. They understood the nuances of the Global Talent route and structured my portfolio to highlight my achievements flawlessly.',
    image: '👩‍💼'
  },
  {
    name: 'Marco Rossi',
    role: 'Tier 1 Investor Visa',
    content: 'As an investor, discretion and speed are paramount. The team delivered a bespoke service that exceeded my highest expectations. A truly elite consultancy.',
    image: '🥂'
  },
  {
    name: 'Linda Chen',
    role: 'Family Sponsorship Route',
    content: 'Reuniting with my family seemed daunting given legislative changes, but the experts at Nirvee Visa mapped out a secure, successful path forward.',
    image: '👩‍⚕️'
  },
  {
    name: 'Ahmed Hassan',
    role: 'EU Blue Card',
    content: 'Their mastery of European immigration frameworks is impressive. I secured my Blue Card without any of the usual bureaucratic friction.',
    image: '👨‍💻'
  },
  {
    name: 'Elena Petrov',
    role: 'Permanent Residency',
    content: 'From the initial strategic assessment to the final visa grant, the communication was immaculate. A premier, client-centric experience from start to finish.',
    image: '👩‍🏫'
  }
];
---

<MainLayout title="Client Testimonials Reviews - Immigration Success Stories" description="Read client testimonials & success stories. 10,000+ successful Canada PR, Australia PR, Germany Job Seeker & UK Study visa approvals. 99% success rate. See reviews.">
  <section class="page-header section-padding" style="background-image: url('/testtermonia.webp'); background-size: cover; background-position: center; background-repeat: no-repeat;">
    <div class="container text-center">
      <span class="uppercase-label" style="color: white;">Client Success</span>
      <h1 style="color: white;">Testimonials</h1>
      <p class="subtitle" style="color: white;">Join the distinguished individuals and corporations who trust us with their global mobility.</p>
    </div>
  </section>

  <section class="testimonials-grid section-padding">
    <div class="container">
      <div class="grid-3">
        {testimonials.map(t => (
          <TestimonialCard {...t} />
        ))}
      </div>
    </div>
  </section>

</MainLayout>

<style>
  .page-header {
    background: var(--background);
    border-bottom: 1px solid var(--border-light);
    padding-top: 150px;
    padding-bottom: 80px;
  }

  .uppercase-label {
    display: inline-block;
    font-family: var(--font-heading);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 16px;
    font-size: 0.9rem;
  }

  .subtitle {
    margin-top: 20px;
    font-size: 1.25rem;
    color: var(--text-muted);
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .grid-3 {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 32px;
  }

  @media (max-width: 992px) {
    .grid-3 {
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 24px;
    }
    .page-header {
      padding-top: 120px;
      padding-bottom: 60px;
    }
  }

  @media (max-width: 768px) {
    .page-header {
      padding-top: 100px;
      padding-bottom: 50px;
    }
    .grid-3 {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .subtitle {
      font-size: 1.1rem;
    }
    .testimonials-grid .glass-card {
      padding: 28px;
    }
  }

  @media (max-width: 480px) {
    .page-header {
      padding-top: 80px;
      padding-bottom: 40px;
    }
    .page-header h1 {
      font-size: 1.75rem;
    }
    .uppercase-label {
      font-size: 0.8rem;
    }
    .subtitle {
      font-size: 1rem;
    }
    .testimonials-grid .glass-card {
      padding: 24px;
    }
  }
</style>
