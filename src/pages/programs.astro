---
import MainLayout from '../layouts/MainLayout.astro';

const programs = [
  {
    title: 'Citizenship by Investment',
    description: 'Elite programs offering second citizenship and passport through strategic real estate investment or sovereign fund contributions in premium jurisdictions.',
    highlights: ['Caribbean Nations', 'European Programs', 'Vanuatu'],
    icon: '🏛️'
  },
  {
    title: 'Golden Visa Programs',
    description: 'Secure residency rights in highly sought-after European nations, providing a direct pathway to citizenship without prohibitive stay requirements.',
    highlights: ['Spain', 'Greece', 'UAE'],
    icon: '🌟'
  },
  {
    title: 'Global Talent Visa',
    description: 'Fast-tracked routes for globally recognized leaders in arts, sciences, tech, and business who wish to establish themselves in top-tier markets.',
    highlights: ['UK Global Talent', 'Australia GTI', 'US O-1'],
    icon: '🏆'
  },
  {
    title: 'Corporate Expansion',
    description: 'Comprehensive mobility solutions tailored specifically for multinational enterprises establishing new regional headquarters.',
    highlights: ['L-1 Visas', 'Sole Representative', 'Intra-Company'],
    icon: '🏢'
  }
];
---

<MainLayout title="Programs" description="Discover our bespoke immigration and citizenship programs.">
  <section class="page-header section-padding">
    <div class="container text-center">
      <span class="gold-text uppercase-label">Premium Solutions</span>
      <h1>Global Programs</h1>
      <p class="subtitle">Curated immigration pathways designed for high-net-worth individuals, top global talent, and expanding corporations.</p>
    </div>
  </section>

  <section class="programs-list section-padding">
    <div class="container">
      <div class="grid programs-grid">
        {programs.map(program => (
          <div class="glass-card program-card">
            <div class="program-header">
              <div class="icon">{program.icon}</div>
              <h2>{program.title}</h2>
            </div>
            <p>{program.description}</p>
            <div class="highlights">
              <span class="highlight-label">Featured Jurisdictions:</span>
              <ul>
                {program.highlights.map(h => <li>{h}</li>)}
              </ul>
            </div>
            <a href="/contact" class="btn btn-outline">Inquire Details</a>
          </div>
        ))}
      </div>
    </div>
  </section>

</MainLayout>

<style>
  .page-header {
    background: var(--background);
    border-bottom: 1px solid var(--border-light);
    padding-top: 150px;
    padding-bottom: 80px;
  }

  .uppercase-label {
    display: inline-block;
    font-family: var(--font-heading);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 16px;
    font-size: 0.9rem;
  }

  .subtitle {
    margin-top: 20px;
    font-size: 1.25rem;
    color: var(--text-muted);
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .programs-grid {
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: 40px;
  }

  .program-card {
    display: flex;
    flex-direction: column;
    padding: 48px;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 16px;
    box-shadow: var(--card-shadow);
  }

  .program-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.05), rgba(219, 39, 119, 0.05));
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: -1;
  }

  .program-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(124, 58, 237, 0.15);
    border-color: var(--primary-pink);
  }

  .program-card:hover::before {
    opacity: 1;
  }

  .program-header {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 24px;
    border-bottom: 1px solid var(--border-light);
    padding-bottom: 24px;
  }

  .icon {
    font-size: 2.5rem;
    background: rgba(124, 58, 237, 0.05);
    padding: 16px;
    border-radius: 12px;
    border: 1px solid rgba(124, 58, 237, 0.1);
    transition: all 0.3s ease;
    position: relative;
  }

  .icon::after {
    content: '';
    position: absolute;
    top: -2px;
    left: -2px;
    right: -2px;
    bottom: -2px;
    background: var(--primary-gradient);
    border-radius: 12px;
    opacity: 0;
    z-index: -1;
    transition: opacity 0.3s ease;
  }

  .program-card:hover .icon {
    transform: scale(1.1) rotate(5deg);
    box-shadow: 0 8px 25px rgba(124, 58, 237, 0.2);
  }

  .program-card:hover .icon::after {
    opacity: 1;
  }

  .program-header h2 {
    margin: 0;
    font-size: 1.8rem;
    transition: all 0.3s ease;
  }

  .program-card:hover .program-header h2 {
    color: var(--primary-purple);
    transform: translateX(4px);
  }

  .program-card p {
    color: var(--text-muted);
    font-size: 1.1rem;
    margin-bottom: 30px;
    flex-grow: 1;
  }

  .highlights {
    margin-bottom: 30px;
    background: var(--background);
    padding: 24px;
    border-radius: 8px;
    border: 1px solid var(--border-light);
  }

  .highlight-label {
    display: block;
    font-family: var(--font-heading);
    color: var(--primary-purple);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.85rem;
    margin-bottom: 12px;
  }

  .highlights ul {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .highlights li {
    background: var(--white);
    padding: 6px 16px;
    border-radius: 4px;
    font-size: 0.9rem;
    color: var(--text-main);
    border: 1px solid var(--card-border);
  }

  .btn-outline {
    align-self: flex-start;
  }

  @media (max-width: 768px) {
    .programs-grid { grid-template-columns: 1fr; }
    .page-header { padding-top: 100px; }
    .program-card { padding: 30px; }
  }
</style>
