---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Free Immigration Eligibility Check Assessment 2025" description="Free immigration eligibility assessment for Canada, Australia, Germany & UK. Check your PR, work visa & study permit qualifications. Instant results & expert recommendations.">
  <section class="page-header section-padding">
    <div class="container text-center">
      <h1>Free Eligibility Assessment</h1>
      <p class="subtitle">Complete this simple form to understand your visa options and get expert recommendations.</p>
    </div>
  </section>

  <section class="assessment-section section-padding">
    <div class="container narrow-container">
      <div class="assessment-card glass">
        <div class="form-progress">
          <div class="step active">1</div>
          <div class="line"></div>
          <div class="step">2</div>
          <div class="line"></div>
          <div class="step">3</div>
        </div>

        <form id="eligibility-form" class="assess-form">
          <div class="step-content" id="step-1">
            <h3>Personal Information</h3>
            <div class="grid-2-form">
              <div class="form-group">
                <label>First Name</label>
                <input type="text" placeholder="First Name" required />
              </div>
              <div class="form-group">
                <label>Last Name</label>
                <input type="text" placeholder="Last Name" required />
              </div>
            </div>
            <div class="form-group">
              <label>Email Address</label>
              <input type="email" placeholder="Email" required />
            </div>
            <div class="form-group">
              <label>Age</label>
              <input type="number" min="18" max="100" placeholder="Your Age" required />
            </div>
          </div>

          <div class="form-actions">
            <button type="button" class="btn btn-primary w-full" id="next-btn">Next Step &rarr;</button>
          </div>
        </form>

        <div class="disclaimer">
          <p><strong>Note:</strong> This assessment is for preliminary information purposes only and does not constitute a formal legal assessment. All information provided is kept strictly confidential.</p>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .page-header {
    background: var(--background);
    border-bottom: 1px solid var(--border-light);
    color: var(--text-main);
    padding-top: 150px;
    padding-bottom: 80px;
  }

  .page-header h1 { color: var(--text-main); }
  
  .subtitle {
    margin-top: 20px;
    font-size: 1.2rem;
    color: var(--gray-light);
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .narrow-container { max-width: 700px; }

  .assessment-card {
    background: var(--card-bg);
    padding: 60px;
    border-radius: 20px;
    box-shadow: var(--card-shadow);
    border: 1px solid var(--card-border);
  }

  .form-progress {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 15px;
    margin-bottom: 50px;
  }

  .step {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #f1f5f9;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    color: var(--text-muted);
  }

  .step.active {
    background: var(--primary-purple);
    color: var(--white);
  }

  .line {
    width: 50px;
    height: 2px;
    background: #f1f5f9;
  }

  .step-content h3 { margin-bottom: 30px; text-align: center; }

  .grid-2-form {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .form-group { margin-bottom: 20px; }
  label { display: block; margin-bottom: 8px; font-weight: 600; color: var(--text-main); }
  input {
    width: 100%;
    padding: 12px 15px;
    border: 1px solid #e5e7eb;
    border-radius: 50px;
    font-family: inherit;
    background: var(--background);
  }

  .w-full { width: 100%; }

  .disclaimer {
    margin-top: 40px;
    padding-top: 20px;
    border-top: 1px solid var(--border-light);
    color: var(--text-muted);
    font-size: 0.85rem;
    text-align: center;
  }

  @media (max-width: 768px) {
    .page-header {
      padding-top: 100px;
      padding-bottom: 50px;
    }
    .assessment-card {
      padding: 30px 24px;
    }
    .form-progress {
      gap: 10px;
      margin-bottom: 30px;
    }
    .step {
      width: 35px;
      height: 35px;
      font-size: 0.9rem;
    }
    .line {
      width: 30px;
    }
    .step-content h3 {
      font-size: 1.3rem;
      margin-bottom: 24px;
    }
    .grid-2-form {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .form-group {
      margin-bottom: 16px;
    }
    .form-group label {
      font-size: 0.95rem;
    }
    input {
      padding: 12px 16px;
      font-size: 16px; /* Prevents zoom on iOS */
    }
    .disclaimer {
      margin-top: 30px;
      font-size: 0.8rem;
    }
    .narrow-container {
      padding: 0 16px;
    }
  }

  @media (max-width: 480px) {
    .page-header {
      padding-top: 80px;
      padding-bottom: 40px;
    }
    .page-header h1 {
      font-size: 1.75rem;
    }
    .subtitle {
      font-size: 1rem;
    }
    .assessment-card {
      padding: 24px 16px;
      border-radius: 16px;
    }
    .form-progress {
      gap: 8px;
      margin-bottom: 24px;
    }
    .step {
      width: 32px;
      height: 32px;
      font-size: 0.85rem;
    }
    .line {
      width: 20px;
    }
    .step-content h3 {
      font-size: 1.2rem;
    }
    input {
      padding: 10px 14px;
      border-radius: 40px;
    }
    .btn {
      padding: 12px 20px;
      font-size: 0.95rem;
    }
    .disclaimer p {
      font-size: 0.75rem;
    }
  }
</style>
