---
import MainLayout from '../layouts/MainLayout.astro';

const team = [
  { name: 'Dr. Sarah Johnson', role: 'Managing Partner', image: '👩‍💼' },
  { name: 'Michael Chen, Esq.', role: 'Head of Corporate Mobility', image: '👨‍💼' },
  { name: 'Emma Williams', role: 'Director, Investor Visas', image: '👩‍💼' },
  { name: 'David Smith', role: 'Senior Global Strategist', image: '👨‍💼' }
];
---

<MainLayout title="About Us" description="Discover the elite firm behind thousands of successful global transitions.">
  <section class="page-header section-padding">
    <div class="container text-center">
      <span class="gold-text uppercase-label">The Firm</span>
      <h1>Excellence in Global Mobility</h1>
      <p class="subtitle">A distinguished consultancy empowering elite professionals, investors, and tier-one corporations to transcend borders effortlessly.</p>
    </div>
  </section>

  <section class="about-content section-padding">
    <div class="container grid-2">
      <div class="about-text">
        <h2 class="gold-text">Our Philosophy</h2>
        <p class="lead">At Nirvee Visa Premium Consulting, we view global mobility not as a bureaucratic hurdle, but as a strategic asset.</p>
        <p>Our mandate is to dismantle the complexities of international relocation. By fusing profound legislative acumen with a white-glove advisory approach, we curate unparalleled immigration strategies that guarantee precision, absolute discretion, and flawless execution.</p>
        
        <div class="values mt-40">
          <div class="value-item">
            <div class="value-icon">✧</div>
            <div>
              <h4 class="gold-text">Unyielding Discretion</h4>
              <p>We manage high-profile cases with absolute confidentiality and supreme professionalism.</p>
            </div>
          </div>
          <div class="value-item">
            <div class="value-icon">✧</div>
            <div>
              <h4 class="gold-text">Bespoke Strategy</h4>
              <p>Abandoning the "one-size-fits-all" model for meticulous, tailored legal frameworks.</p>
            </div>
          </div>
        </div>
      </div>
      <div class="about-image glass-card p-0">
        <div class="image-placeholder">
          <span class="placeholder-text">Unparalleled Authority</span>
        </div>
      </div>
    </div>
  </section>

  <section class="team section-padding bg-darker">
    <div class="container text-center">
      <span class="gold-text uppercase-label">Leadership</span>
      <h2>Our Senior Strategists</h2>
      <p class="subtitle mb-60">Pioneers in global immigration law and corporate mobility.</p>
      
      <div class="team-grid">
        {team.map(member => (
          <div class="team-card">
            <div class="team-avatar">{member.image}</div>
            <div class="team-info">
              <h3>{member.name}</h3>
              <p class="gold-text">{member.role}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .page-header {
    background: var(--background);
    border-bottom: 1px solid var(--border-light);
    padding-top: 150px;
    padding-bottom: 80px;
  }

  .uppercase-label {
    display: inline-block;
    font-family: var(--font-heading);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 16px;
    font-size: 0.9rem;
  }

  .subtitle {
    margin-top: 20px;
    font-size: 1.25rem;
    color: var(--text-muted);
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .grid-2 {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 80px;
    align-items: center;
  }

  .about-text h2 { margin-bottom: 30px; font-size: 2.5rem; }
  .about-text p { margin-bottom: 24px; color: var(--text-muted); font-size: 1.1rem; }
  .about-text .lead { color: var(--text-main); font-size: 1.35rem; font-weight: 300; }

  .mt-40 { margin-top: 50px; }

  .value-item {
    display: flex;
    gap: 24px;
    margin-bottom: 30px;
    align-items: flex-start;
  }

  .value-icon {
    font-size: 1.5rem;
    color: var(--primary-purple);
    flex-shrink: 0;
    line-height: 1;
    margin-top: 4px;
  }

  .value-item h4 { margin-bottom: 8px; font-size: 1.2rem; }
  .value-item p { margin-bottom: 0; font-size: 1rem; }

  .p-0 { padding: 0 !important; overflow: hidden; border-radius: 12px; }

  .image-placeholder {
    height: 500px;
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.1), rgba(219, 39, 119, 0.1));
    background-size: cover;
    background-position: center;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .placeholder-text {
    background: var(--white);
    backdrop-filter: blur(10px);
    padding: 16px 32px;
    border: 1px solid var(--card-border);
    color: var(--primary-purple);
    font-family: var(--font-heading);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: 0.9rem;
    border-radius: 4px;
  }

  .bg-darker {
    background-color: var(--background);
    border-top: 1px solid var(--border-light);
  }

  .mb-60 { margin-bottom: 60px; }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 40px;
  }

  .team-card {
    background: var(--white);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    overflow: hidden;
    transition: var(--transition);
    box-shadow: var(--card-shadow);
  }

  .team-card:hover {
    transform: translateY(-10px);
    border-color: var(--primary-pink);
    box-shadow: 0 20px 40px rgba(124, 58, 237, 0.15);
  }

  .team-avatar {
    height: 250px;
    background: rgba(124, 58, 237, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 5rem;
    border-bottom: 1px solid var(--border-light);
  }

  .team-info {
    padding: 30px;
  }

  .team-card h3 { font-size: 1.3rem; margin-bottom: 8px; }
  .team-card p { font-weight: 500; font-size: 0.9rem; letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 0; }

  @media (max-width: 992px) {
    .grid-2 { grid-template-columns: 1fr; }
    .image-placeholder { height: 400px; }
  }

  @media (max-width: 768px) {
    .page-header { padding-top: 100px; }
  }
</style>
