---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="About Nirvee Visa Immigration Experts" description="Learn about Nirvee Visa - Immigration consultants with 7+ years experience, 99% approval rate & 10,000+ successful clients. Serving Canada, Australia, Germany, UK & more. Free consultation.">
  <section class="page-header section-padding" style="background-image: url('/emigration.webp'); background-size: cover; background-position: center; background-repeat: no-repeat;">
    <div class="container text-center">
      <span class="uppercase-label" style="color: rgb(244, 218, 244);">The Firm</span>
      <h1 style="color: white;">Excellence in Global Mobility</h1>
      <p class="subtitle" style="color: white;">Empowering your global journey through empathy, diverse language support, and a shared immigrant background.</p>
    </div>
  </section>

  <section class="about-content section-padding">
    <div class="container grid-2">
      <div class="about-text">
        <h2 class="gold-text">Our Philosophy</h2>
        <p class="lead">At Nirvee Visa & Experts Pvt Ltd, we understand that choosing to immigrate is one of the most significant decisions you will ever make. That’s why we are dedicated to making your future our top priority.</p>
        <p>With our immigrant background, we truly relate to the challenges you face at every stage of your journey. To support you better, we offer our services in 12 diverse languages, including English, Tamil, Sinhalese, Urdu, Hindi, Punjabi, Tagalog, Ukrainian, Russian, Italian, Albanian, and Portuguese.</p>
        <p>We look forward to hearing your story and helping you achieve your immigration goals!</p>
        
      </div>
      <div class="about-image glass-card p-0">
        <div class="logo-container">
          <img src="/logo.webp" alt="Nirvee Visa & Immigration Experts Logo - Trusted Immigration Consultancy Since 2017" class="about-logo" />
        </div>
      </div>
    </div>
  </section>

</MainLayout>

<style>
  .page-header {
    background: var(--background);
    border-bottom: 1px solid var(--border-light);
    padding-top: 150px;
    padding-bottom: 80px;
  }

  .uppercase-label {
    display: inline-block;
    font-family: var(--font-heading);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 16px;
    font-size: 0.9rem;
  }

  .subtitle {
    margin-top: 20px;
    font-size: 1.25rem;
    color: var(--text-muted);
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .grid-2 {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 80px;
    align-items: center;
  }

  .about-text h2 { margin-bottom: 30px; font-size: 2.5rem; }
  .about-text p { margin-bottom: 24px; color: var(--text-muted); font-size: 1.1rem; }
  .about-text .lead { color: var(--text-main); font-size: 1.35rem; font-weight: 300; }

  .mt-40 { margin-top: 50px; }

  .value-item {
    display: flex;
    gap: 24px;
    margin-bottom: 30px;
    align-items: flex-start;
  }

  .value-icon {
    font-size: 1.5rem;
    color: var(--primary-purple);
    flex-shrink: 0;
    line-height: 1;
    margin-top: 4px;
  }

  .value-item h4 { margin-bottom: 8px; font-size: 1.2rem; }
  .value-item p { margin-bottom: 0; font-size: 1rem; }

  .p-0 { padding: 0 !important; overflow: hidden; border-radius: 12px; }

  .logo-container {
    height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--card-bg);
  }

  .about-logo {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 20px;
  }

  .image-placeholder {
    height: 500px;
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.1), rgba(219, 39, 119, 0.1));
    background-size: cover;
    background-position: center;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .placeholder-text {
    background: var(--white);
    backdrop-filter: blur(10px);
    padding: 16px 32px;
    border: 1px solid var(--card-border);
    color: var(--primary-purple);
    font-family: var(--font-heading);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: 0.9rem;
    border-radius: 4px;
  }

  .bg-darker {
    background-color: var(--background);
    border-top: 1px solid var(--border-light);
  }

  .mb-60 { margin-bottom: 60px; }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 40px;
  }

  .team-card {
    background: var(--white);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    overflow: hidden;
    transition: var(--transition);
    box-shadow: var(--card-shadow);
  }

  .team-card:hover {
    transform: translateY(-10px);
    border-color: var(--primary-pink);
    box-shadow: 0 20px 40px rgba(124, 58, 237, 0.15);
  }

  .team-avatar {
    height: 250px;
    background: rgba(124, 58, 237, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 5rem;
    border-bottom: 1px solid var(--border-light);
  }

  .team-info {
    padding: 30px;
  }

  .team-card h3 { font-size: 1.3rem; margin-bottom: 8px; }
  .team-card p { font-weight: 500; font-size: 0.9rem; letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 0; }

  @media (max-width: 992px) {
    .grid-2 {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .image-placeholder { height: 400px; }
    .logo-container { height: 400px; }
    .about-text h2 {
      font-size: 2rem;
    }
    .about-text .lead {
      font-size: 1.2rem;
    }
  }

  @media (max-width: 768px) {
    .page-header {
      padding-top: 100px;
      padding-bottom: 60px;
    }
    .about-content {
      padding: 30px 0;
    }
    .about-text h2 {
      font-size: 1.75rem;
    }
    .about-text p {
      font-size: 1rem;
    }
    .about-text .lead {
      font-size: 1.1rem;
    }
    .logo-container {
      height: 350px;
      border-radius: 12px;
    }
    .about-logo {
      padding: 16px;
    }
    .team-grid {
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 24px;
    }
    .team-avatar {
      height: 200px;
    }
    .team-info {
      padding: 20px;
    }
    .team-card h3 {
      font-size: 1.2rem;
    }
  }

  @media (max-width: 480px) {
    .page-header {
      padding-top: 80px;
      padding-bottom: 50px;
    }
    .about-text h2 {
      font-size: 1.5rem;
      margin-bottom: 20px;
    }
    .about-text p {
      font-size: 0.95rem;
      margin-bottom: 16px;
    }
    .logo-container {
      height: 300px;
    }
    .about-logo {
      padding: 12px;
    }
    .value-item {
      flex-direction: column;
      gap: 12px;
      text-align: center;
    }
    .value-icon {
      margin: 0 auto;
    }
    .team-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
