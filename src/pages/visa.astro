---
import MainLayout from '../layouts/MainLayout.astro';

const countries = [
  { name: 'Canada', flag: '🇨🇦', categories: ['Express Entry', 'PNP', 'Study Permit'] },
  { name: 'Australia', flag: '🇦🇺', categories: ['Skilled Independent', 'State Nominated', 'Student'] },
  { name: 'United Kingdom', flag: '🇬🇧', categories: ['Skilled Worker', 'Student Visa', 'Global Talent'] },
  { name: 'USA', flag: '🇺🇸', categories: ['H1-B', 'F-1 Student', 'EB-1/EB-2'] },
  { name: 'Germany', flag: '🇩🇪', categories: ['Opportunity Card', 'Blue Card', 'Student'] },
  { name: 'New Zealand', flag: '🇳🇿', categories: ['Skilled Migrant', 'Accredited Employer', 'Student'] }
];
---

<MainLayout title="Visa & Country Options" description="Discover migration opportunities in top destinations worldwide.">
  <section class="page-header section-padding">
    <div class="container text-center">
      <h1>Explore Your Destinations</h1>
      <p class="subtitle">Detailed information for the world's most sought-after immigration destinations.</p>
    </div>
  </section>

  <section class="visa-categories section-padding">
    <div class="container">
      <div class="grid-3">
        {countries.map(country => (
          <div class="country-card glass">
            <div class="country-top">
              <span class="flag">{country.flag}</span>
              <h3>{country.name}</h3>
            </div>
            <div class="categories">
              <h4>Popular Pathways:</h4>
              <ul>
                {country.categories.map(cat => (
                  <li>{cat}</li>
                ))}
              </ul>
            </div>
            <a href="/contact" class="btn btn-primary-outline btn-sm">Enquire Now</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="visa-types section-padding bg-light">
    <div class="container">
      <h2 class="text-center">Major Visa Categories</h2>
      
      <div class="visa-detail-grid">
        <div class="visa-detail-item" id="skilled">
          <h3>Skilled Migration</h3>
          <p>For professionals with qualified skills and experience looking for permanent residency in countries like Canada, Australia, and the UK. Typically based on a points system considering age, education, and work experience.</p>
        </div>
        <div class="visa-detail-item" id="study">
          <h3>Study Permits</h3>
          <p>The gateway to global education. We help you secure admissions and the subsequent study visas for top-ranking universities and colleges worldwide.</p>
        </div>
        <div class="visa-detail-item" id="family">
          <h3>Family & Spouse Visas</h3>
          <p>Bringing families together across borders. Specialized assistance for spouse, partner, parent, and child visa applications with strict adherence to relationship evidence requirements.</p>
        </div>
        <div class="visa-detail-item" id="business">
          <h3>Business & Investment</h3>
          <p>For entrepreneurs and investors looking to establish businesses or invest in a new country. Focus on high-value migration and economic contribution.</p>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .page-header {
    background: var(--background);
    border-bottom: 1px solid var(--border-light);
    color: var(--text-main);
    padding-top: 150px;
    padding-bottom: 80px;
  }

  .page-header h1 { color: var(--text-main); }
  
  .subtitle {
    margin-top: 20px;
    font-size: 1.2rem;
    color: var(--gray-light);
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .grid-3 {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
  }

  .country-card {
    background: var(--card-bg);
    padding: 30px;
    border-radius: 12px;
    border: 1px solid var(--card-border);
    display: flex;
    flex-direction: column;
    transition: var(--transition);
    box-shadow: var(--card-shadow);
  }

  .country-card:hover { 
    border-color: var(--primary-pink); 
    transform: translateY(-8px); 
    box-shadow: 0 20px 40px rgba(124, 58, 237, 0.15);
  }

  .country-top { display: flex; align-items: center; gap: 15px; margin-bottom: 20px; }
  .flag { font-size: 2.5rem; }
  .country-top h3 { font-size: 1.5rem; }

  .categories { margin-bottom: 25px; }
  .categories h4 { font-size: 0.9rem; color: var(--primary-purple); margin-bottom: 10px; }
  .categories ul { padding-left: 20px; }
  .categories ul li { list-style: disc; font-size: 0.95rem; margin-bottom: 5px; color: var(--text-muted); }

  .btn-sm { padding: 8px 16px; font-size: 0.85rem; align-self: flex-start; }

  .bg-light { 
    background-color: var(--background); 
    border-top: 1px solid var(--border-light);
  }

  .visa-detail-grid {
    margin-top: 50px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
  }

  .visa-detail-item {
    background: var(--white);
    padding: 30px;
    border-radius: 12px;
    border-left: 4px solid var(--primary-purple);
    box-shadow: var(--card-shadow);
  }

  .visa-detail-item h3 { margin-bottom: 15px; font-size: 1.3rem; }
  .visa-detail-item p { color: var(--text-muted); font-size: 0.95rem; line-height: 1.7; }

  @media (max-width: 768px) {
    .visa-detail-grid { grid-template-columns: 1fr; }
  }
</style>
