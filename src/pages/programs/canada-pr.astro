---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Canada PR (Express Entry)" description="Canada Permanent Residence through Express Entry system">
  <section class="page-header section-padding">
    <div class="container text-center">
      <span class="gold-text uppercase-label">PR Pathway</span>
      <h1>Canada PR (Express Entry)</h1>
      <p class="subtitle">Fast-track your permanent residence in Canada through the Express Entry system.</p>
    </div>
  </section>

  <section class="visitor-visa-content section-padding">
    <div class="container">
      <div class="content-grid">
        <div class="glass-card content-section">
          <div class="section-icon">stars</div>
          <h2>Express Entry Programs</h2>
          <div class="highlight-box">
            <ul>
              <li><strong>Federal Skilled Worker (FSW)</strong> - For skilled professionals with foreign work experience</li>
              <li><strong>Canadian Experience Class (CEC)</strong> - For those with Canadian work experience</li>
              <li><strong>Federal Skilled Trades (FST)</strong> - For qualified tradespeople</li>
              <li>All programs use the Comprehensive Ranking System (CRS)</li>
            </ul>
          </div>
        </div>

        <div class="glass-card content-section">
          <div class="section-icon">trending_up</div>
          <h2>CRS Points System</h2>
          <p>Maximum 1,200 points based on:</p>
          <div class="highlight-box">
            <ul>
              <li>Age (max 110 points for ages 20-29)</li>
              <li>Education (max 150 points for PhD)</li>
              <li>Language proficiency (max 136 points per language)</li>
              <li>Work experience (max 80 points Canadian, 50 foreign)</li>
              <li>Provincial nomination (600 bonus points)</li>
              <li>Arranged employment (up to 200 points)</li>
            </ul>
          </div>
        </div>

        <div class="glass-card content-section">
          <div class="section-icon">attach_money</div>
          <h2>Financial Requirements</h2>
          <p>Settlement funds required (2024 estimates):</p>
          <div class="highlight-box">
            <ul>
              <li>Single applicant: CAD $13,757</li>
              <li>Family of 2: CAD $17,127</li>
              <li>Family of 3: CAD $21,055</li>
              <li>Family of 4: CAD $25,564</li>
              <li>Proof of funds letter from bank required</li>
            </ul>
          </div>
        </div>

        <div class="glass-card content-section">
          <div class="section-icon">schedule</div>
          <h2>Application Process & Timeline</h2>
          <p>Steps to PR:</p>
          <div class="highlight-box">
            <ul>
              <li>Step 1: Create Express Entry profile (valid 12 months)</li>
              <li>Step 2: Get ITA in bi-weekly draws (current cutoff ~500+ CRS)</li>
              <li>Step 3: Submit complete application within 60 days</li>
              <li>Processing time: 6 months from complete application</li>
              <li>Permanent Resident Card valid for 5 years</li>
            </ul>
          </div>
        </div>

        <div class="glass-card content-section">
          <div class="section-icon">emoji_events</div>
          <h2>Path to Citizenship</h2>
          <p>After PR:</p>
          <div class="highlight-box">
            <ul>
              <li>Live in Canada for 3 out of 5 years (1,095 days)</li>
              <li>File taxes for at least 3 years</li>
              <li>Pass citizenship test (knowledge of Canada)</li>
              <li>Language proficiency proof required (CLB 4)</li>
              <li>Apply for Canadian citizenship</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section section-padding bg-darker">
    <div class="container text-center">
      <h2>Ready for Canadian Permanent Residence?</h2>
      <p class="subtitle">Let our experts calculate your CRS score and guide you through Express Entry.</p>
      <div class="cta-buttons">
        <a href="/contact" class="btn btn-primary">Get Started</a>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .page-header {
    background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url('/pr/Canada.webp') center/cover no-repeat;
    border-bottom: 1px solid var(--border-light);
    padding-top: 150px;
    padding-bottom: 80px;
  }
  .page-header h1 {
    color: white;
  }
  .uppercase-label {
    color: white;
    display: inline-block;
    font-family: var(--font-heading);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 16px;
    font-size: 0.9rem;
  }
  .subtitle {
    margin-top: 20px;
    font-size: 1.25rem;
    color: white;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }
  .content-grid {
    display: grid;
    gap: 40px;
    max-width: 900px;
    margin: 0 auto;
  }
  .content-section {
    padding: 40px;
    border-radius: 16px;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    box-shadow: var(--card-shadow);
    position: relative;
    overflow: hidden;
  }
  .content-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.03), rgba(219, 39, 119, 0.03));
    z-index: -1;
  }
  .section-icon {
    font-size: 2.5rem;
    margin-bottom: 24px;
    color: var(--primary-purple);
    opacity: 0.8;
    font-family: 'Material Icons';
    font-weight: normal;
    font-style: normal;
  }
  .content-section h2 {
    font-size: 2rem;
    margin-bottom: 20px;
    color: var(--text-main);
    font-weight: 600;
  }
  .content-section p {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 24px;
    font-size: 1.1rem;
  }
  .highlight-box {
    background: rgba(124, 58, 237, 0.05);
    border: 1px solid rgba(124, 58, 237, 0.1);
    border-radius: 12px;
    padding: 24px;
    margin-top: 24px;
  }
  .highlight-box ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .highlight-box li {
    position: relative;
    padding-left: 24px;
    margin-bottom: 12px;
    color: var(--text-muted);
    line-height: 1.6;
  }
  .highlight-box li::before {
    content: 'check_circle';
    position: absolute;
    left: 0;
    color: var(--primary-purple);
    font-size: 1.2rem;
    font-family: 'Material Icons';
    font-weight: normal;
    font-style: normal;
  }
  .bg-darker {
    background-color: var(--background);
    border-top: 1px solid var(--border-light);
  }
  .cta-section h2 {
    font-size: 2.5rem;
    margin-bottom: 20px;
    color: var(--text-main);
  }
  .cta-buttons {
    display: flex;
    gap: 20px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 40px;
  }
  .btn {
    padding: 16px 32px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    display: inline-block;
    font-size: 1.1rem;
  }
  .btn-primary {
    background: var(--primary-gradient);
    color: white;
    border: none;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(124, 58, 237, 0.3);
  }
  @media (max-width: 992px) {
    .page-header {
      padding-top: 120px;
      padding-bottom: 70px;
    }
    .content-section {
      padding: 32px;
    }
    .content-section h2 {
      font-size: 1.8rem;
    }
    .section-icon {
      font-size: 2rem;
    }
    .content-section p {
      font-size: 1rem;
    }
    .cta-section h2 {
      font-size: 2.2rem;
    }
  }

  @media (max-width: 768px) {
    .page-header {
      padding-top: 100px;
      padding-bottom: 60px;
    }
    .page-header h1 {
      font-size: 1.75rem;
    }
    .uppercase-label {
      font-size: 0.8rem;
    }
    .subtitle {
      font-size: 1rem;
    }
    .content-grid {
      gap: 24px;
    }
    .content-section {
      padding: 24px;
      border-radius: 12px;
    }
    .content-section h2 {
      font-size: 1.5rem;
      margin-bottom: 16px;
    }
    .section-icon {
      font-size: 1.75rem;
      margin-bottom: 16px;
    }
    .content-section p {
      font-size: 0.95rem;
      margin-bottom: 16px;
    }
    .highlight-box {
      padding: 16px;
      margin-top: 16px;
    }
    .highlight-box li {
      padding-left: 20px;
      margin-bottom: 8px;
      font-size: 0.9rem;
    }
    .highlight-box li::before {
      font-size: 1rem;
    }
    .cta-section {
      padding: 60px 0;
    }
    .cta-section h2 {
      font-size: 1.75rem;
    }
    .cta-buttons {
      flex-direction: column;
      align-items: center;
      gap: 16px;
      margin-top: 30px;
    }
    .btn {
      width: 100%;
      max-width: 280px;
      padding: 14px 28px;
      font-size: 1rem;
    }
  }

  @media (max-width: 480px) {
    .page-header {
      padding-top: 80px;
      padding-bottom: 50px;
    }
    .page-header h1 {
      font-size: 1.5rem;
    }
    .subtitle {
      font-size: 0.9rem;
    }
    .content-section {
      padding: 20px;
    }
    .content-section h2 {
      font-size: 1.3rem;
    }
    .highlight-box {
      padding: 14px;
    }
    .highlight-box li {
      font-size: 0.85rem;
    }
    .cta-section h2 {
      font-size: 1.5rem;
    }
    .btn {
      padding: 12px 24px;
      font-size: 0.95rem;
    }
  }
</style>
