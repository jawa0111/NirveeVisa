---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Austria Job Seeker Visa 2025 - Red-White-Red Card" description="Apply for Austria Job Seeker Visa in 2025. Red-White-Red Card requirements: qualifications, experience & points system. 6-month job search visa for Austria. Free consultation.">
  <section class="page-header section-padding">
    <div class="container text-center">
      <span class="gold-text uppercase-label">Job Seeker Visa</span>
      <h1>Austria Job Seeker Visa</h1>
      <p class="subtitle">Launch your career in Austria with the Red-White-Red Card for qualified workers.</p>
    </div>
  </section>

  <section class="visitor-visa-content section-padding">
    <div class="container">
      <div class="content-grid">
        <div class="glass-card content-section">
          <div class="section-icon">work</div>
          <h2>Eligibility Requirements</h2>
          <div class="highlight-box">
            <ul>
              <li>Qualification from a university or college</li>
              <li>Minimum 70 points on the Red-White-Red Card scale</li>
              <li>Relevant work experience in shortage occupations</li>
              <li>German language skills (A2 level minimum)</li>
              <li>Age under 45 years preferred</li>
              <li>Proof of accommodation in Austria</li>
            </ul>
          </div>
        </div>

        <div class="glass-card content-section">
          <div class="section-icon">attach_money</div>
          <h2>Financial Requirements</h2>
          <p>You must demonstrate sufficient funds:</p>
          <div class="highlight-box">
            <ul>
              <li>Approximately €1,200 per month for living expenses</li>
              <li>Blocked account or bank guarantee</li>
              <li>Valid for 6-month stay period</li>
              <li>Health insurance coverage required</li>
            </ul>
          </div>
        </div>

        <div class="glass-card content-section">
          <div class="section-icon">schedule</div>
          <h2>Red-White-Red Card Points System</h2>
          <p>Points awarded for:</p>
          <div class="highlight-box">
            <ul>
              <li>Qualifications (up to 30 points)</li>
              <li>Work experience (up to 20 points)</li>
              <li>Language skills (up to 20 points)</li>
              <li>Age (up to 20 points)</li>
              <li>Studies in Austria (up to 10 points)</li>
            </ul>
          </div>
        </div>

        <div class="glass-card content-section">
          <div class="section-icon">groups</div>
          <h2>Duration & Path Forward</h2>
          <p>Visa details and conversion:</p>
          <div class="highlight-box">
            <ul>
              <li>Job Seeker Visa valid for 6 months</li>
              <li>Can apply for Red-White-Red Card upon job offer</li>
              <li>Red-White-Red Card valid for 24 months</li>
              <li>Pathway to permanent residence after 5 years</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section section-padding bg-darker">
    <div class="container text-center">
      <h2>Ready to Work in Austria?</h2>
      <p class="subtitle">Let our experts guide you through the Austria Job Seeker Visa process.</p>
      <div class="cta-buttons">
        <a href="/contact" class="btn btn-primary">Get Started</a>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .page-header {
    background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url('/job/Australia.webp') center/cover no-repeat;
    border-bottom: 1px solid var(--border-light);
    padding-top: 150px;
    padding-bottom: 80px;
  }
  .page-header h1 {
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .header-flag {
    width: 48px;
    height: 32px;
    object-fit: cover;
    border-radius: 4px;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
  }
  .uppercase-label {
    display: inline-block;
    font-family: var(--font-heading);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 16px;
    font-size: 0.9rem;
  }
  .subtitle {
    margin-top: 20px;
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.9);
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }
  .content-grid {
    display: grid;
    gap: 40px;
    max-width: 900px;
    margin: 0 auto;
  }
  .content-section {
    padding: 40px;
    border-radius: 16px;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    box-shadow: var(--card-shadow);
    position: relative;
    overflow: hidden;
  }
  .content-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.03), rgba(219, 39, 119, 0.03));
    z-index: -1;
  }
  .section-icon {
    font-size: 2.5rem;
    margin-bottom: 24px;
    color: var(--primary-purple);
    opacity: 0.8;
    font-family: 'Material Icons';
    font-weight: normal;
    font-style: normal;
  }
  .content-section h2 {
    font-size: 2rem;
    margin-bottom: 20px;
    color: var(--text-main);
    font-weight: 600;
  }
  .content-section p {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 24px;
    font-size: 1.1rem;
  }
  .highlight-box {
    background: rgba(124, 58, 237, 0.05);
    border: 1px solid rgba(124, 58, 237, 0.1);
    border-radius: 12px;
    padding: 24px;
    margin-top: 24px;
  }
  .highlight-box ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .highlight-box li {
    position: relative;
    padding-left: 24px;
    margin-bottom: 12px;
    color: var(--text-muted);
    line-height: 1.6;
  }
  .highlight-box li::before {
    content: 'check_circle';
    position: absolute;
    left: 0;
    color: var(--primary-purple);
    font-size: 1.2rem;
    font-family: 'Material Icons';
    font-weight: normal;
    font-style: normal;
  }
  .bg-darker {
    background-color: var(--background);
    border-top: 1px solid var(--border-light);
  }
  .cta-section h2 {
    font-size: 2.5rem;
    margin-bottom: 20px;
    color: var(--text-main);
  }
  .cta-buttons {
    display: flex;
    gap: 20px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 40px;
  }
  .btn {
    padding: 16px 32px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    display: inline-block;
    font-size: 1.1rem;
  }
  .btn-primary {
    background: var(--primary-gradient);
    color: white;
    border: none;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(124, 58, 237, 0.3);
  }
  @media (max-width: 768px) {
    .page-header { padding-top: 100px; padding-bottom: 60px; }
    .content-section { padding: 24px; }
    .content-section h2 { font-size: 1.5rem; }
    .cta-section h2 { font-size: 2rem; }
    .cta-buttons { flex-direction: column; align-items: center; }
    .btn { width: 100%; max-width: 300px; }
  }
</style>
