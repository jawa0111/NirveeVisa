---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="UK Settlement Visa ILR 2025 - Indefinite Leave to Remain" description="Apply for UK Settlement Visa & ILR in 2025. Work visa routes to permanent residency. Skilled Worker, Global Talent & family settlement pathways. Expert UK immigration advice.">
  <section class="page-header section-padding">
    <div class="container text-center">
      <span class="gold-text uppercase-label">PR Pathway</span>
      <h1>UK Settlement Visa (ILR)</h1>
      <p class="subtitle">Secure indefinite leave to remain in the UK through various settlement routes.</p>
    </div>
  </section>

  <section class="visitor-visa-content section-padding">
    <div class="container">
      <div class="content-grid">
        <div class="glass-card content-section">
          <div class="section-icon">stars</div>
          <h2>Settlement Routes</h2>
          <div class="highlight-box">
            <ul>
              <li><strong>Skilled Worker to ILR:</strong> After 5 years on Skilled Worker visa</li>
              <li><strong>Global Talent to ILR:</strong> 3 or 5 years depending on endorsement</li>
              <li><strong>Innovator Founder:</strong> After 3 years of business activity</li>
              <li><strong>Family route:</strong> Partner or parent of UK resident</li>
              <li><strong>Long residence:</strong> 10 years legal continuous residence</li>
              <li><strong>EU Settlement Scheme:</strong> For eligible EU citizens (deadline passed)</li>
            </ul>
          </div>
        </div>

        <div class="glass-card content-section">
          <div class="section-icon">verified</div>
          <h2>ILR Requirements (Skilled Worker)</h2>
          <p>General requirements for settlement:</p>
          <div class="highlight-box">
            <ul>
              <li>Continuous 5-year lawful residence in UK</li>
              <li>Valid skilled worker visa throughout</li>
              <li>Salary meets minimum threshold (£26,200 or going rate)</li>
              <li>Pass Life in the UK Test</li>
              <li>English language B1 level or higher</li>
              <li>No absences exceeding 180 days in any 12-month period</li>
            </ul>
          </div>
        </div>

        <div class="glass-card content-section">
          <div class="section-icon">attach_money</div>
          <h2>Application Fees & Costs</h2>
          <p>Settlement costs (2024 estimates):</p>
          <div class="highlight-box">
            <ul>
              <li>ILR application fee: £2,885 per person</li>
              <li>Biometric enrolment: £19.20</li>
              <li>Life in the UK Test: £50</li>
              <li>English test (if needed): £150-200</li>
              <li>Priority service (optional): £500-800</li>
              <li>Super priority service: £1,000</li>
            </ul>
          </div>
        </div>

        <div class="glass-card content-section">
          <div class="section-icon">schedule</div>
          <h2>Processing & Timeline</h2>
          <p>Application details:</p>
          <div class="highlight-box">
            <ul>
              <li>Standard processing: 6 months</li>
              <li>Priority service: 5 working days</li>
              <li>Super priority: Next working day decision</li>
              <li>Apply online via gov.uk before current visa expires</li>
              <li>Attend biometric appointment</li>
              <li>Decision sent via email/post</li>
            </ul>
          </div>
        </div>

        <div class="glass-card content-section">
          <div class="section-icon">emoji_events</div>
          <h2>ILR to British Citizenship</h2>
          <p>After obtaining ILR:</p>
          <div class="highlight-box">
            <ul>
              <li>Eligible to apply for citizenship after 12 months</li>
              <li>Must have held ILR for at least 12 months</li>
              <li>Meet residence requirements (not absent > 450 days in 5 years)</li>
              <li>Pass Life in the UK Test (if not already done)</li>
              <li>Prove English language proficiency</li>
              <li>Good character requirement applies</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section section-padding bg-darker">
    <div class="container text-center">
      <h2>Ready for UK Settlement?</h2>
      <p class="subtitle">Let our experts guide you through the ILR application process.</p>
      <div class="cta-buttons">
        <a href="/contact" class="btn btn-primary">Get Started</a>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .page-header {
    background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url('/pr/UK.webp') center/cover no-repeat;
    border-bottom: 1px solid var(--border-light);
    padding-top: 150px;
    padding-bottom: 80px;
  }
  .page-header h1 {
    color: white;
  }
  .uppercase-label {
    color: white;
    display: inline-block;
    font-family: var(--font-heading);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 16px;
    font-size: 0.9rem;
  }
  .subtitle {
    margin-top: 20px;
    font-size: 1.25rem;
    color: white;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }
  .content-grid {
    display: grid;
    gap: 40px;
    max-width: 900px;
    margin: 0 auto;
  }
  .content-section {
    padding: 40px;
    border-radius: 16px;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    box-shadow: var(--card-shadow);
    position: relative;
    overflow: hidden;
  }
  .content-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.03), rgba(219, 39, 119, 0.03));
    z-index: -1;
  }
  .section-icon {
    font-size: 2.5rem;
    margin-bottom: 24px;
    color: var(--primary-purple);
    opacity: 0.8;
    font-family: 'Material Icons';
    font-weight: normal;
    font-style: normal;
  }
  .content-section h2 {
    font-size: 2rem;
    margin-bottom: 20px;
    color: var(--text-main);
    font-weight: 600;
  }
  .content-section p {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 24px;
    font-size: 1.1rem;
  }
  .highlight-box {
    background: rgba(124, 58, 237, 0.05);
    border: 1px solid rgba(124, 58, 237, 0.1);
    border-radius: 12px;
    padding: 24px;
    margin-top: 24px;
  }
  .highlight-box ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .highlight-box li {
    position: relative;
    padding-left: 24px;
    margin-bottom: 12px;
    color: var(--text-muted);
    line-height: 1.6;
  }
  .highlight-box li::before {
    content: 'check_circle';
    position: absolute;
    left: 0;
    color: var(--primary-purple);
    font-size: 1.2rem;
    font-family: 'Material Icons';
    font-weight: normal;
    font-style: normal;
  }
  .bg-darker {
    background-color: var(--background);
    border-top: 1px solid var(--border-light);
  }
  .cta-section h2 {
    font-size: 2.5rem;
    margin-bottom: 20px;
    color: var(--text-main);
  }
  .cta-buttons {
    display: flex;
    gap: 20px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 40px;
  }
  .btn {
    padding: 16px 32px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    display: inline-block;
    font-size: 1.1rem;
  }
  .btn-primary {
    background: var(--primary-gradient);
    color: white;
    border: none;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(124, 58, 237, 0.3);
  }
  @media (max-width: 768px) {
    .page-header { padding-top: 100px; padding-bottom: 60px; }
    .content-section { padding: 24px; }
    .content-section h2 { font-size: 1.5rem; }
    .cta-section h2 { font-size: 2rem; }
    .cta-buttons { flex-direction: column; align-items: center; }
    .btn { width: 100%; max-width: 300px; }
  }
</style>
