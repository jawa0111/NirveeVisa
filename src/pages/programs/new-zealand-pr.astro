---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="New Zealand PR Skilled Migrant 2025 - Permanent Residence" description="Apply for New Zealand PR in 2025 via Skilled Migrant Category. EOI points requirements, SMC visa pathway & job offer criteria. Expert NZ immigration consultants. Free assessment.">
  <section class="page-header section-padding">
    <div class="container text-center">
      <span class="gold-text uppercase-label">PR Pathway</span>
      <h1>New Zealand Permanent Residence</h1>
      <p class="subtitle">Secure your future in New Zealand through the Skilled Migrant Category.</p>
    </div>
  </section>

  <section class="visitor-visa-content section-padding">
    <div class="container">
      <div class="content-grid">
        <div class="glass-card content-section">
          <div class="section-icon">stars</div>
          <h2>Skilled Migrant Category (SMC)</h2>
          <div class="highlight-box">
            <ul>
              <li>Points-based system for skilled workers</li>
              <li>Minimum 6 points required (new system from 2023)</li>
              <li>Based on skilled work in NZ, qualifications, or income</li>
              <li>Job offer from accredited employer required</li>
              <li>Or current skilled employment in New Zealand</li>
            </ul>
          </div>
        </div>

        <div class="glass-card content-section">
          <div class="section-icon">trending_up</div>
          <h2>6-Point System (2023 onwards)</h2>
          <p>Gain points from ONE of the following:</p>
          <div class="highlight-box">
            <ul>
              <li><strong>Professional Registration + Experience:</strong> 3-6 points</li>
              <li><strong>Qualifications:</strong> 3-6 points (Bachelor to PhD)</li>
              <li><strong>Income:</strong> 3-6 points (1.5x to 3x median wage)</li>
              <li><strong>New Zealand Skilled Work:</strong> 1 point per year (max 3)</li>
              <li>Need total of 6 points to apply</li>
            </ul>
          </div>
        </div>

        <div class="glass-card content-section">
          <div class="section-icon">verified</div>
          <h2>Other Pathways to Residence</h2>
          <p>Alternative options:</p>
          <div class="highlight-box">
            <ul>
              <li><strong>Work to Residence:</strong> For those in specific shortage roles</li>
              <li><strong>Green List Straight to Residence:</strong> For top-tier shortage occupations</li>
              <li><strong>Green List Work to Residence:</strong> 2 years in specific role</li>
              <li><strong>Family Category:</strong> Partner or parent sponsorship</li>
              <li><strong>Entrepreneur Residence:</strong> For business owners</li>
            </ul>
          </div>
        </div>

        <div class="glass-card content-section">
          <div class="section-icon">attach_money</div>
          <h2>Visa Fees & Processing</h2>
          <p>Application details:</p>
          <div class="highlight-box">
            <ul>
              <li>Online application fee: NZD $4,890 (approx.)</li>
              <li>Paper application: NZD $5,390 (approx.)</li>
              <li>Processing time: 6-12 months typically</li>
              <li>EOI submission required before application</li>
              <li>Must meet health and character requirements</li>
            </ul>
          </div>
        </div>

        <div class="glass-card content-section">
          <div class="section-icon">emoji_events</div>
          <h2>Resident Visa Conditions</h2>
          <p>After approval:</p>
          <div class="highlight-box">
            <ul>
              <li>Initial travel conditions valid for 2 years</li>
              <li>Live, work, study in NZ indefinitely</li>
              <li>Access to public healthcare and education</li>
              <li>Sponsor family members</li>
              <li>Apply for permanent resident visa after 2 years</li>
              <li>Citizenship eligibility after 5 years as resident</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section section-padding bg-darker">
    <div class="container text-center">
      <h2>Ready for New Zealand Permanent Residence?</h2>
      <p class="subtitle">Let our experts assess your 6-point eligibility and guide your application.</p>
      <div class="cta-buttons">
        <a href="/contact" class="btn btn-primary">Get Started</a>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .page-header {
    background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url('/pr/New_Zealand .webp') center/cover no-repeat;
    border-bottom: 1px solid var(--border-light);
    padding-top: 150px;
    padding-bottom: 80px;
  }
  .page-header h1 {
    color: white;
  }
  .uppercase-label {
    color: white;
    display: inline-block;
    font-family: var(--font-heading);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 16px;
    font-size: 0.9rem;
  }
  .subtitle {
    margin-top: 20px;
    font-size: 1.25rem;
    color: white;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }
  .content-grid {
    display: grid;
    gap: 40px;
    max-width: 900px;
    margin: 0 auto;
  }
  .content-section {
    padding: 40px;
    border-radius: 16px;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    box-shadow: var(--card-shadow);
    position: relative;
    overflow: hidden;
  }
  .content-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.03), rgba(219, 39, 119, 0.03));
    z-index: -1;
  }
  .section-icon {
    font-size: 2.5rem;
    margin-bottom: 24px;
    color: var(--primary-purple);
    opacity: 0.8;
    font-family: 'Material Icons';
    font-weight: normal;
    font-style: normal;
  }
  .content-section h2 {
    font-size: 2rem;
    margin-bottom: 20px;
    color: var(--text-main);
    font-weight: 600;
  }
  .content-section p {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 24px;
    font-size: 1.1rem;
  }
  .highlight-box {
    background: rgba(124, 58, 237, 0.05);
    border: 1px solid rgba(124, 58, 237, 0.1);
    border-radius: 12px;
    padding: 24px;
    margin-top: 24px;
  }
  .highlight-box ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .highlight-box li {
    position: relative;
    padding-left: 24px;
    margin-bottom: 12px;
    color: var(--text-muted);
    line-height: 1.6;
  }
  .highlight-box li::before {
    content: 'check_circle';
    position: absolute;
    left: 0;
    color: var(--primary-purple);
    font-size: 1.2rem;
    font-family: 'Material Icons';
    font-weight: normal;
    font-style: normal;
  }
  .bg-darker {
    background-color: var(--background);
    border-top: 1px solid var(--border-light);
  }
  .cta-section h2 {
    font-size: 2.5rem;
    margin-bottom: 20px;
    color: var(--text-main);
  }
  .cta-buttons {
    display: flex;
    gap: 20px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 40px;
  }
  .btn {
    padding: 16px 32px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    display: inline-block;
    font-size: 1.1rem;
  }
  .btn-primary {
    background: var(--primary-gradient);
    color: white;
    border: none;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(124, 58, 237, 0.3);
  }
  @media (max-width: 768px) {
    .page-header { padding-top: 100px; padding-bottom: 60px; }
    .content-section { padding: 24px; }
    .content-section h2 { font-size: 1.5rem; }
    .cta-section h2 { font-size: 2rem; }
    .cta-buttons { flex-direction: column; align-items: center; }
    .btn { width: 100%; max-width: 300px; }
  }
</style>
