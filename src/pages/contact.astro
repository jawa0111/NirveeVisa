---
import MainLayout from '../layouts/MainLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<MainLayout title="Contact Immigration Consultants - Free Consultation" description="Contact Nirvee Visa for free immigration consultation. Expert advisors for Canada PR, Australia PR, Germany Job Seeker Visa, UK Study Permits. Call +49 176 74966603 or email today.">
  <section class="page-header section-padding" style="background-image: url('/contactus.webp'); background-size: cover; background-position: center; background-repeat: no-repeat;">
    <div class="container text-center">
      <span class="gold-text uppercase-label drop-shadow" style="color: white;">Inquiries</span>
      <h1 style="color: white;">Request Consultation</h1>
      <p class="subtitle" style="color: white;">Engage with our senior advisory team to define your bespoke global mobility strategy.</p>
    </div>
  </section>

  <section class="contact-section section-padding">
    <div class="container grid-2">
      <div class="contact-info">
        <h2 class="gold-text">Global Headquarters</h2>
        <p class="lead">We maintain absolute discretion for all inquiries. Select the most convenient channel below, or submit our secure portal form.</p>
        
        <div class="info-blocks mt-40">
          <div class="info-item">
            <div class="icon-wrapper">
              <span class="icon">⌂</span>
            </div>
            <div>
              <h4 class="gold-text">Corporate Office</h4>
              <p>No 131, Adiyapatham Road,<br/>Kokuvil East, Kokuvil, Jaffna 40000, Sri Lanka</p>
            </div>
          </div>
          <div class="info-item">
            <div class="icon-wrapper">
              <span class="icon">✆</span>
            </div>
            <div>
              <h4 class="gold-text">Direct Line</h4>
              <p>+49 176 74966603</p>
            </div>
          </div>
          <div class="info-item">
            <div class="icon-wrapper">
              <span class="icon">✉</span>
            </div>
            <div>
              <h4 class="gold-text">Secure Email</h4>
              <p>nirveevisaimmigirationexperts@gmail.com</p>
            </div>
          </div>
        </div>
      </div>

      <div class="contact-form-wrapper">
        <ContactForm />
      </div>
    </div>
  </section>

  <section class="faq-section section-padding">
    <div class="container">
      <div class="text-center mb-50">
        <span class="gold-text uppercase-label drop-shadow">Support</span>
        <h2>Frequently Asked Questions</h2>
        <p class="subtitle">Find answers to common questions about our immigration services</p>
      </div>

      <div class="faq-accordion">
        <div class="faq-item">
          <button class="faq-question">
            <span>Q1. What services does Nirvee Visa offer?</span>
            <span class="faq-icon">›</span>
          </button>
          <div class="faq-answer">
            <p>We specialize in PR Pathway programs, Study Permits, and Job Seeker Visas for multiple countries including Canada, Australia, Germany, and the UK. Our services cover the entire process from initial consultation to visa approval.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question">
            <span>Q2. How long does the visa application process take?</span>
            <span class="faq-icon">›</span>
          </button>
          <div class="faq-answer">
            <p>Processing times vary by country and visa type. Study permits typically take 4-8 weeks, PR applications 6-12 months, and job seeker visas 2-6 weeks. We provide accurate timelines during your consultation based on your specific case.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question">
            <span>Q3. What documents are required for visa applications?</span>
            <span class="faq-icon">›</span>
          </button>
          <div class="faq-answer">
            <p>Common requirements include a valid passport, proof of funds, educational credentials, work experience letters, language test results (IELTS/TOEFL), and medical/police clearance certificates. We provide a complete checklist tailored to your destination.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question">
            <span>Q4. Do you help with job placement for Job Seeker Visas?</span>
            <span class="faq-icon">›</span>
          </button>
          <div class="faq-answer">
            <p>Yes, we assist with resume optimization, job market research, and connecting you with employers in your target country. While we don't guarantee employment, our partnerships with recruitment agencies significantly improve your job search success.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question">
            <span>Q5. Can I work while studying on a Student Visa?</span>
            <span class="faq-icon">›</span>
          </button>
          <div class="faq-answer">
            <p>Most countries allow international students to work part-time (20 hours/week during term, full-time during breaks). We guide you on work permit regulations for your specific study destination to ensure compliance.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question">
            <span>Q6. What is your consultation fee?</span>
            <span class="faq-icon">›</span>
          </button>
          <div class="faq-answer">
            <p>Initial consultations are free. Our service fees vary based on visa complexity and destination country. We provide transparent pricing with no hidden charges. Contact us for a detailed quote tailored to your immigration goals.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question">
            <span>Q7. Do you assist with visa rejections and reapplications?</span>
            <span class="faq-icon">›</span>
          </button>
          <div class="faq-answer">
            <p>Absolutely. We analyze rejection reasons, strengthen your application with additional documentation, and guide you through the appeal or reapplication process. Our experience with complex cases increases your chances of approval.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question">
            <span>Q8. Which countries do you specialize in?</span>
            <span class="faq-icon">›</span>
          </button>
          <div class="faq-answer">
            <p>We have expertise in Canada (Express Entry, PNP), Australia (Skilled Migration, Student Visas), Germany (Job Seeker Visa, Blue Card), UK (Work Visas, Student Routes), and New Zealand. Our team stays updated on changing immigration policies.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="map-section">
    <div class="map-container">
      <iframe
        src="https://maps.google.com/maps?q=131+Adiyapatham+Road,Kokuvil+East,Jaffna+40000,Sri+Lanka&z=16&output=embed"
        width="100%"
        height="400"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Nirvee Visa & Experts Location"
      ></iframe>
    </div>
  </section>

</MainLayout>

<script is:inline>
  // FAQ Accordion functionality
  document.querySelectorAll('.faq-question').forEach(button => {
    button.addEventListener('click', function() {
      const faqItem = this.parentElement;
      const isActive = faqItem.classList.contains('active');
      
      // Close all items
      document.querySelectorAll('.faq-item').forEach(item => {
        item.classList.remove('active');
      });
      
      // Open clicked item if it wasn't already active
      if (!isActive) {
        faqItem.classList.add('active');
      }
    });
  });
</script>

<style>
  .page-header {
    background: var(--background);
    border-bottom: 1px solid var(--border-light);
    padding-top: 150px;
    padding-bottom: 80px;
  }

  .uppercase-label {
    display: inline-block;
    font-family: var(--font-heading);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 16px;
    font-size: 0.9rem;
  }

  .subtitle {
    margin-top: 20px;
    font-size: 1.25rem;
    color: var(--text-muted);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .grid-2 {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 80px;
    align-items: flex-start;
  }

  .contact-info h2 { margin-bottom: 24px; font-size: 2.2rem; }
  .contact-info .lead { margin-bottom: 40px; color: var(--text-main); font-weight: 300; font-size: 1.2rem; }

  .mt-40 { margin-top: 50px; }
  .info-blocks { display: flex; flex-direction: column; gap: 40px; }

  .info-item {
    display: flex;
    gap: 24px;
    align-items: center;
  }

  .icon-wrapper {
    background: rgba(124, 58, 237, 0.05);
    border: 1px solid rgba(124, 58, 237, 0.2);
    width: 60px;
    height: 60px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: var(--transition);
  }

  .icon {
    font-size: 2rem;
    color: var(--primary-purple);
    line-height: 1;
  }

  .info-item:hover .icon-wrapper {
    background: var(--primary-gradient);
    border-color: transparent;
  }

  .info-item:hover .icon {
    color: var(--white);
  }

  .info-item h4 { margin-bottom: 8px; font-size: 1.1rem; }
  .info-item p { margin-bottom: 0; font-size: 1rem; color: var(--text-muted); line-height: 1.5; }

  @media (max-width: 992px) {
    .grid-2 { grid-template-columns: 1fr; gap: 60px; }
  }

  @media (max-width: 768px) {
    .page-header { padding-top: 100px; }
  }

  .map-section {
    padding: 0;
    margin: 0;
  }

  .map-container {
    width: 100%;
    height: 400px;
    overflow: hidden;
  }

  .map-container iframe {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }

  .faq-section {
    background: var(--background);
    border-top: 1px solid var(--border-light);
  }

  .mb-50 {
    margin-bottom: 50px;
  }

  .faq-accordion {
    max-width: 900px;
    margin: 0 auto;
  }

  .faq-item {
    border: 1px solid var(--border-light);
    border-bottom: none;
    background: var(--white);
    transition: var(--transition);
  }

  .faq-item:last-child {
    border-bottom: 1px solid var(--border-light);
  }

  .faq-item:hover {
    background: var(--background-alt);
  }

  .faq-question {
    width: 100%;
    padding: 24px 30px;
    background: none;
    border: none;
    text-align: left;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-heading);
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    transition: var(--transition);
    font-family: var(--font-body);
  }

  .faq-question:hover {
    color: var(--primary-purple);
  }

  .faq-icon {
    font-size: 1.5rem;
    color: var(--primary-purple);
    transition: transform 0.3s ease;
    flex-shrink: 0;
  }

  .faq-item.active .faq-icon {
    transform: rotate(90deg);
  }

  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
    padding: 0 30px;
  }

  .faq-item.active .faq-answer {
    max-height: 300px;
    padding: 0 30px 24px 30px;
  }

  .faq-answer p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin: 0;
  }

  @media (max-width: 992px) {
    .grid-2 {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .contact-info h2 {
      font-size: 1.8rem;
    }
    .contact-info .lead {
      font-size: 1.1rem;
    }
    .mt-40 {
      margin-top: 30px;
    }
    .info-blocks {
      gap: 24px;
    }
    .info-item {
      gap: 16px;
    }
    .icon-wrapper {
      width: 50px;
      height: 50px;
    }
    .icon {
      font-size: 1.5rem;
    }
  }

  @media (max-width: 768px) {
    .page-header {
      padding-top: 100px;
      padding-bottom: 60px;
    }
    .grid-2 {
      gap: 30px;
    }
    .contact-info h2 {
      font-size: 1.6rem;
    }
    .contact-info .lead {
      font-size: 1rem;
    }
    .info-item {
      flex-direction: column;
      gap: 12px;
      text-align: center;
    }
    .icon-wrapper {
      margin: 0 auto;
    }
    .faq-question {
      padding: 18px 20px;
      font-size: 1rem;
    }
    .faq-answer {
      padding: 0 20px;
    }
    .faq-item.active .faq-answer {
      padding: 0 20px 18px 20px;
    }
    .faq-icon {
      font-size: 1.3rem;
    }
    .map-container {
      height: 300px;
    }
  }

  @media (max-width: 480px) {
    .page-header {
      padding-top: 80px;
      padding-bottom: 50px;
    }
    .contact-info h2 {
      font-size: 1.4rem;
    }
    .info-item h4 {
      font-size: 1rem;
    }
    .info-item p {
      font-size: 0.9rem;
    }
    .faq-question {
      padding: 14px 16px;
      font-size: 0.95rem;
    }
    .faq-answer p {
      font-size: 0.9rem;
    }
    .map-container {
      height: 250px;
    }
  }
</style>
