---
import MainLayout from '../layouts/MainLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<MainLayout title="Contact Us" description="Schedule a private consultation with our senior immigration strategists.">
  <section class="page-header section-padding">
    <div class="container text-center">
      <span class="gold-text uppercase-label drop-shadow">Inquiries</span>
      <h1>Request Consultation</h1>
      <p class="subtitle">Engage with our senior advisory team to define your bespoke global mobility strategy.</p>
    </div>
  </section>

  <section class="contact-section section-padding">
    <div class="container grid-2">
      <div class="contact-info">
        <h2 class="gold-text">Global Headquarters</h2>
        <p class="lead">We maintain absolute discretion for all inquiries. Select the most convenient channel below, or submit our secure portal form.</p>
        
        <div class="info-blocks mt-40">
          <div class="info-item">
            <div class="icon-wrapper">
              <span class="icon">⌂</span>
            </div>
            <div>
              <h4 class="gold-text">Corporate Office</h4>
              <p>123 Obsidian Tower, Suite 400<br/>New York, NY 10001</p>
            </div>
          </div>
          <div class="info-item">
            <div class="icon-wrapper">
              <span class="icon">✆</span>
            </div>
            <div>
              <h4 class="gold-text">Direct Line</h4>
              <p>+1 (234) 567-890</p>
            </div>
          </div>
          <div class="info-item">
            <div class="icon-wrapper">
              <span class="icon">✉</span>
            </div>
            <div>
              <h4 class="gold-text">Secure Email</h4>
              <p>advisory@nirvee-visa.com</p>
            </div>
          </div>
        </div>
      </div>

      <div class="contact-form-wrapper">
        <ContactForm />
      </div>
    </div>
  </section>

</MainLayout>

<style>
  .page-header {
    background: var(--background);
    border-bottom: 1px solid var(--border-light);
    padding-top: 150px;
    padding-bottom: 80px;
  }

  .uppercase-label {
    display: inline-block;
    font-family: var(--font-heading);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 16px;
    font-size: 0.9rem;
  }

  .subtitle {
    margin-top: 20px;
    font-size: 1.25rem;
    color: var(--text-muted);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .grid-2 {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 80px;
    align-items: flex-start;
  }

  .contact-info h2 { margin-bottom: 24px; font-size: 2.2rem; }
  .contact-info .lead { margin-bottom: 40px; color: var(--text-main); font-weight: 300; font-size: 1.2rem; }

  .mt-40 { margin-top: 50px; }
  .info-blocks { display: flex; flex-direction: column; gap: 40px; }

  .info-item {
    display: flex;
    gap: 24px;
    align-items: center;
  }

  .icon-wrapper {
    background: rgba(124, 58, 237, 0.05);
    border: 1px solid rgba(124, 58, 237, 0.2);
    width: 60px;
    height: 60px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: var(--transition);
  }

  .icon {
    font-size: 2rem;
    color: var(--primary-purple);
    line-height: 1;
  }

  .info-item:hover .icon-wrapper {
    background: var(--primary-gradient);
    border-color: transparent;
  }

  .info-item:hover .icon {
    color: var(--white);
  }

  .info-item h4 { margin-bottom: 8px; font-size: 1.1rem; }
  .info-item p { margin-bottom: 0; font-size: 1rem; color: var(--text-muted); line-height: 1.5; }

  @media (max-width: 992px) {
    .grid-2 { grid-template-columns: 1fr; gap: 60px; }
  }

  @media (max-width: 768px) {
    .page-header { padding-top: 100px; }
  }
</style>
