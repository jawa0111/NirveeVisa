---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Permanent Residency Options" description="Pathways to Canadian permanent residency including Family Sponsorship and Economic Immigration">
  <section class="page-header section-padding">
    <div class="container text-center">
      <span class="gold-text uppercase-label">Visa Services</span>
      <h1>Permanent Residency Options</h1>
      <p class="subtitle">Canadian citizens and permanent residents can sponsor family members. Economic immigration programs are also available.</p>
    </div>
  </section>

  <section class="visitor-visa-content section-padding">
    <div class="container">
      <div class="content-grid">
        <!-- Family Sponsorship Section -->
        <div class="glass-card content-section">
          <div class="section-icon">family_restroom</div>
          <h2>Family Sponsorship</h2>
          <p>Citizens and permanent residents can sponsor spouses, partners, and dependent children. The process involves legal, health, and criminal background checks.</p>
          <div class="highlight-box">
            <h3>Parent and Grandparent Sponsorship:</h3>
            <ul>
              <li>Now operates via a lottery system</li>
              <li>Applications submitted online during specific periods</li>
            </ul>
          </div>
          <p><strong>Other Family Members:</strong> You may also sponsor adopted children, orphaned siblings under 18, and certain relatives under special circumstances.</p>
        </div>

        <!-- Economic Immigration Section -->
        <div class="glass-card content-section">
          <div class="section-icon">trending_up</div>
          <h2>Economic Immigration</h2>
          
          <div class="highlight-box">
            <h3>Express Entry:</h3>
            <ul>
              <li>An online system managing applications for Federal Skilled Worker, Canadian Experience Class, and Provincial Nominee programs</li>
              <li>Candidates are ranked by their CRS score</li>
              <li>The highest-ranked candidates receive Invitations to Apply (ITAs)</li>
            </ul>
          </div>

          <div class="highlight-box">
            <h3>Provincial Nominee Program (PNP):</h3>
            <ul>
              <li>Provinces select candidates based on regional needs</li>
              <li>Successful nominees apply for permanent residence</li>
            </ul>
          </div>
        </div>

        <!-- Contact Note -->
        <div class="glass-card content-section">
          <div class="section-icon">contact_mail</div>
          <h2>Other Countries</h2>
          <p>For other countries, contact us for more details.</p>
        </div>

      </div>
    </div>
  </section>

  <section class="cta-section section-padding bg-darker">
    <div class="container text-center">
      <h2>Need Help?</h2>
      <p class="subtitle">Our experienced immigration team is ready to assist you at every step.</p>
      <div class="cta-buttons">
        <a href="/contact" class="btn btn-primary">Contact Us Today</a>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .page-header {
    background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url('/permanent.png') center/cover no-repeat;
    border-bottom: 1px solid var(--border-light);
    padding-top: 150px;
    padding-bottom: 80px;
  }
  .page-header h1 {
    color: white;
  }
  .uppercase-label {
    display: inline-block;
    font-family: var(--font-heading);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 16px;
    font-size: 0.9rem;
    color:white;
  }

  .subtitle {
    margin-top: 20px;
    font-size: 1.25rem;
    color: white;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .content-grid {
    display: grid;
    gap: 40px;
    max-width: 900px;
    margin: 0 auto;
  }

  .content-section {
    padding: 40px;
    border-radius: 16px;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    box-shadow: var(--card-shadow);
    position: relative;
    overflow: hidden;
  }

  .content-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.03), rgba(219, 39, 119, 0.03));
    z-index: -1;
  }

  .section-icon {
    font-size: 2.5rem;
    margin-bottom: 24px;
    color: var(--primary-purple);
    opacity: 0.8;
    font-family: 'Material Icons';
    font-weight: normal;
    font-style: normal;
  }

  .content-section h2 {
    font-size: 2rem;
    margin-bottom: 20px;
    color: var(--text-main);
    font-weight: 600;
  }

  .content-section p {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 24px;
    font-size: 1.1rem;
  }

  .highlight-box {
    background: rgba(124, 58, 237, 0.05);
    border: 1px solid rgba(124, 58, 237, 0.1);
    border-radius: 12px;
    padding: 24px;
    margin-top: 24px;
  }

  .highlight-box h3 {
    color: var(--primary-purple);
    margin-bottom: 16px;
    font-size: 1.3rem;
  }

  .highlight-box ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .highlight-box li {
    position: relative;
    padding-left: 24px;
    margin-bottom: 12px;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .highlight-box li::before {
    content: 'check_circle';
    position: absolute;
    left: 0;
    color: var(--primary-purple);
    font-size: 1.2rem;
    font-family: 'Material Icons';
    font-weight: normal;
    font-style: normal;
  }

  .bg-darker {
    background-color: var(--background);
    border-top: 1px solid var(--border-light);
  }

  .cta-section h2 {
    font-size: 2.5rem;
    margin-bottom: 20px;
    color: var(--text-main);
  }

  .cta-buttons {
    display: flex;
    gap: 20px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 40px;
  }

  .btn {
    padding: 16px 32px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    display: inline-block;
    font-size: 1.1rem;
  }

  .btn-primary {
    background: var(--primary-gradient);
    color: white;
    border: none;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(124, 58, 237, 0.3);
  }

  @media (max-width: 768px) {
    .page-header { 
      padding-top: 100px; 
      padding-bottom: 60px;
    }
    
    .content-section {
      padding: 24px;
    }
    
    .content-section h2 {
      font-size: 1.5rem;
    }
    
    .cta-section h2 {
      font-size: 2rem;
    }
    
    .cta-buttons {
      flex-direction: column;
      align-items: center;
    }
    
    .btn {
      width: 100%;
      max-width: 300px;
    }
  }
</style>