  function fixProgramsCarousel() {
    const cards = document.querySelectorAll('.program-carousel-card');
    cards.forEach((card) => {
      const imgFile = card.getAttribute('data-img');
      if (imgFile) {
        card.style.backgroundImage = `url('/${imgFile}')`;
      }
    });
  }

  function fixServicesGallery() {
    const cards = document.querySelectorAll('.service-gallery-card');
    cards.forEach((card) => {
      const imgFile = card.getAttribute('data-img');
      if (imgFile) {
        card.style.backgroundImage = `url('/${imgFile}')`;
      }
    });
  }

  document.addEventListener('astro:page-load', () => {
    const cards = document.querySelectorAll('.slider-card');
    
    cards.forEach(card => {
      card.addEventListener('click', () => {
        cards.forEach(c => c.classList.remove('active'));
        card.classList.add('active');
      });
    });

    fixServiceBanners();
    fixProgramsCarousel();
    fixServicesGallery();
  });

  document.addEventListener('astro:after-swap', () => {
    fixServiceBanners();
    fixProgramsCarousel();
    fixServicesGallery();
  });

  fixServiceBanners();
  fixProgramsCarousel();
  fixServicesGallery();
</script>
