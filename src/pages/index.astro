---
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';

const services = [
  {
    icon: '🏢',
    title: 'Work Visas',
    description: 'Expert assistance for skilled worker Visas and corporate employment sponsors globally.',
    link: '/services#work'
  },
  {
    icon: '🎓',
    title: 'Study Visas',
    description: 'Complete guidance for international students to top-tier universities worldwide.',
    link: '/services#study'
  },
  {
    icon: '🏠',
    title: 'Family Visas',
    description: 'Reuniting families with expedited spouse, child, and parental visa applications.',
    link: '/services#family'
  },
  {
    icon: '✈️',
    title: 'Investor Visas',
    description: 'Bespoke programs for high-net-worth individuals seeking citizenship by investment.',
    link: '/programs#investor'
  }
];
---

<MainLayout title="Home" description="Premium immigration consultancy services for your global mobility.">
  
  <Hero 
    title="Elite Global Mobility Solutions." 
    subtitle="Leverage our unparalleled expertise to navigate complex global immigration landscapes with absolute precision."
    ctaText="Consult With Us"
    ctaLink="/contact"
  />

  <section class="services section-padding">
    <div class="container">
      <div class="section-header text-center">
        <span class="gold-text uppercase-label">Our Capabilities</span>
        <h2>Bespoke Immigration Services</h2>
        <p class="lead">We deliver comprehensive strategies tailored for individuals and corporations seeking seamless global mobility.</p>
      </div>
      <div class="grid service-grid">
        {services.map(service => (
          <ServiceCard {...service} />
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section section-padding">
    <div class="container relative">
      <div class="glass-cta">
        <div class="cta-content">
          <span class="gold-text uppercase-label drop-shadow">Take the Next Step</span>
          <h2>Secure Your Global Future</h2>
          <p>Schedule a private consultation with our senior immigration strategists to outline your optimal path forward.</p>
          <a href="/contact" class="btn btn-primary">Request Consultation</a>
        </div>
      </div>
    </div>
  </section>

  <section class="stats section-padding">
    <div class="container stat-grid">
      <div class="stat-item">
        <span class="stat-number">15+</span>
        <span class="stat-label">Years of Excellence</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">10K+</span>
        <span class="stat-label">Successful Clients</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">64</span>
        <span class="stat-label">Jurisdictions</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">99%</span>
        <span class="stat-label">Approval Rate</span>
      </div>
    </div>
  </section>

</MainLayout>

<style>
  .uppercase-label {
    display: block;
    font-family: var(--font-heading);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 16px;
    font-size: 0.9rem;
  }

  .section-header {
    max-width: 700px;
    margin: 0 auto 70px;
  }

  .service-grid {
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 32px;
  }

  .cta-section {
    position: relative;
    padding: 120px 0;
    margin: 40px 0;
  }

  .cta-section::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 80%;
    height: 120%;
    background: radial-gradient(circle, rgba(124, 58, 237, 0.1) 0%, rgba(219, 39, 119, 0.05) 50%, rgba(255, 255, 255, 0) 100%);
    z-index: 0;
    pointer-events: none;
  }

  .glass-cta {
    background: var(--white);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    padding: 80px 40px;
    text-align: center;
    position: relative;
    z-index: 1;
    box-shadow: var(--card-shadow);
  }

  .cta-content h2 {
    font-size: 3rem;
    margin-bottom: 24px;
    font-weight: 800;
    letter-spacing: -1px;
    color: var(--text-main);
  }

  .cta-content p {
    font-size: 1.25rem;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto 40px;
  }

  .stats {
    background-color: var(--background);
    border-top: 1px solid var(--border-light);
    border-bottom: 1px solid var(--border-light);
  }

  .stat-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    text-align: center;
    gap: 40px;
  }

  .stat-item {
    padding: 20px;
  }

  .stat-number {
    display: block;
    font-family: var(--font-heading);
    font-size: 4rem;
    font-weight: 800;
    background: var(--primary-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 8px;
    line-height: 1;
  }

  .stat-label {
    font-family: var(--font-heading);
    font-weight: 500;
    color: var(--text-main);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.9rem;
  }

  @media (max-width: 992px) {
    .stat-grid { grid-template-columns: 1fr 1fr; }
    .cta-content h2 { font-size: 2.5rem; }
  }

  @media (max-width: 768px) {
    .glass-cta { padding: 40px 20px; }
    .stat-number { font-size: 3rem; }
  }
</style>
