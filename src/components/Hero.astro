---
interface Props {
  title: string;
  subtitle: string;
  ctaText: string;
  ctaLink: string;
}

const { title, subtitle, ctaText, ctaLink } = Astro.props;
---

<section class="hero">
  <div class="overlay"></div>
  <div class="container hero-content">
    <div class="hero-text-wrapper">
      <div class="badge">Premium Consultancy</div>
      <h1 class="hero-title">{title}</h1>
      <p class="hero-subtitle">{subtitle}</p>
      <div class="hero-actions">
        <a href={ctaLink} class="btn btn-primary">{ctaText}</a>
        <a href="/programs" class="btn btn-outline">Explore Programs</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    height: 90vh;
    min-height: 700px;
    background-image: url('/elegant-abstract-world-map-featuring-golden-lines-black-background-representation-showcases-symbolizing-global-357525222.webp');
    background-size: cover;
    background-position: center;
    background-attachment: scroll;
    position: relative;
    display: flex;
    align-items: center;
    margin-top: -85px; /* Offset the header */
    padding-top: 85px;
    image-rendering: high-quality;
    animation: mapDrift 40s linear infinite alternate;
  }

  @keyframes mapDrift {
    0% { background-position: 0% center; background-size: 100%; }
    100% { background-position: 10% center; background-size: 110%; }
  }

  .overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(10, 10, 10, 0.9) 0%, rgba(10, 10, 10, 0.6) 50%, rgba(20, 20, 20, 0.8) 100%);
  }

  .hero-content {
    position: relative;
    z-index: 10;
    width: 100%;
  }

  .hero-text-wrapper {
    max-width: 850px;
  }

  .badge {
    display: inline-block;
    padding: 6px 16px;
    background: rgba(212, 175, 55, 0.1);
    border: 1px solid rgba(212, 175, 55, 0.3);
    color: var(--gold);
    border-radius: 4px;
    font-size: 0.85rem;
    font-family: var(--font-heading);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 30px;
    animation: fadeInUp 0.8s cubic-bezier(0.25, 0.8, 0.25, 1);
  }

  .hero-title {
    color: var(--white);
    font-size: 4.5rem;
    line-height: 1.1;
    margin-bottom: 30px;
    animation: fadeInUp 0.8s cubic-bezier(0.25, 0.8, 0.25, 1) 0.1s backwards;
  }

  .hero-subtitle {
    font-size: 1.35rem;
    margin-bottom: 40px;
    color: var(--text-muted);
    font-weight: 300;
    max-width: 650px;
    animation: fadeInUp 0.8s cubic-bezier(0.25, 0.8, 0.25, 1) 0.2s backwards;
  }

  .hero-actions {
    display: flex;
    gap: 24px;
    animation: fadeInUp 0.8s cubic-bezier(0.25, 0.8, 0.25, 1) 0.3s backwards;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 992px) {
    .hero-title { font-size: 3.5rem; }
  }

  @media (max-width: 768px) {
    .hero-title { font-size: 2.8rem; }
    .hero-subtitle { font-size: 1.1rem; }
    .hero-actions { flex-direction: column; gap: 16px; }
    .hero-actions .btn { width: 100%; }
  }
</style>
