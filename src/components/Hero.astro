---
interface Props {
  title: string;
  subtitle: string;
  ctaText: string;
  ctaLink: string;
}

const { title, subtitle, ctaText, ctaLink } = Astro.props;
---

<section id="hero-architectural" style="display: flex; height: calc(100vh - 80px); min-height: 600px; background-color: #1a1a2e; align-items: center; justify-content: center; position: relative; overflow: hidden; width: 100%;">
  
  <!-- BACKGROUND SLIDESHOW -->
  <div class="hero-slideshow">
    <div class="slide active" style="background-image: url('/design.webp');"></div>
    <div class="slide" style="background-image: url('/h2.webp');"></div>
    <div class="slide" style="background-image: url('/h3.webp');"></div>
    <div class="slide" style="background-image: url('/h4.webp');"></div>
   
    <div class="slide-overlay"></div>
  </div>

  <!-- CONTENT LAYER -->
  <div class="container" style="position: relative; z-index: 10; display: flex; justify-content: center; text-align: center; width: 100%;">
    <div style="max-width: 1100px;">
      
      <h1 
        id="hero-rotating-title"
        style="font-size: clamp(1.8rem, 4.5vw, 3.5rem); font-weight: 800; color: #ffffff; line-height: 1.1; letter-spacing: -1.2px; margin-bottom: 25px; text-shadow: 0 2px 10px rgba(0,0,0,0.5); font-family: 'Outfit', sans-serif; transition: opacity 0.8s ease, transform 0.8s ease;" 
        set:html={title} 
      />
      
      <p style="font-size: clamp(1.1rem, 3vw, 1.6rem); color: #ffffff; max-width: 750px; margin: 0 auto 50px; font-weight: 400; line-height: 1.5; font-family: 'Inter', sans-serif; text-shadow: 0 2px 8px rgba(0,0,0,0.4);">
        {subtitle}
      </p>
      
      <div class="hero-buttons">
        <a href={ctaLink} class="hero-btn hero-btn-primary">
          Consult With Us
        </a>
        <a href="/programs/new-programs" class="hero-btn hero-btn-outline">
          Explore Programs
        </a>
      </div>
    </div>
  </div>

</section>

<style is:inline>
  /* Hero Button Styles */
  .hero-buttons {
    display: flex;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 18px 40px;
    border-radius: 50px;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.3s ease;
    text-align: center;
    min-width: 180px;
  }

  .hero-btn-primary {
    background: linear-gradient(135deg, #7C3AED 0%, #DB2777 100%);
    color: white;
    box-shadow: 0 10px 25px rgba(124, 58, 237, 0.3);
  }

  .hero-btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 35px rgba(124, 58, 237, 0.4);
  }

  .hero-btn-outline {
    background: rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(10px);
    border: 2px solid rgba(255, 255, 255, 0.8);
    color: #ffffff;
    box-shadow: 0 4px 15px rgba(0,0,0,0.2);
  }

  .hero-btn-outline:hover {
    background: rgba(255, 255, 255, 0.3);
    transform: translateY(-3px);
  }

  @media (max-width: 640px) {
    .hero-buttons {
      flex-direction: column;
      align-items: center;
      gap: 15px;
    }

    .hero-btn {
      width: 100%;
      max-width: 280px;
      padding: 16px 30px;
      font-size: 0.95rem;
    }
  }

  @media (max-width: 480px) {
    .hero-btn {
      padding: 14px 24px;
      font-size: 0.9rem;
      min-width: auto;
    }
  }

  /* Background Slideshow Styles */
  #hero-architectural {
    width: 100vw;
    max-width: 100%;
    left: 0;
    right: 0;
  }

  .hero-slideshow {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    overflow: hidden;
  }

  .hero-slideshow .slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    opacity: 0;
    transition: opacity 1.5s ease-in-out;
    image-rendering: -webkit-optimize-contrast;
    image-rendering: crisp-edges;
  }

  .hero-slideshow .slide.active {
    opacity: 1;
  }

  .hero-slideshow .slide-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    z-index: 2;
  }

  /* Fallback and responsive styles that can't be inlined easily */
  @media (max-width: 768px) {
    #hero-architectural { 
      height: calc(100vh - 70px) !important;
      min-height: 500px !important;
    }
    #hero-architectural .elite-actions {
      flex-direction: column !important;
    }
  }

  @media (max-height: 700px) {
    #hero-architectural {
      height: auto !important;
      min-height: calc(100vh - 80px) !important;
    }
  }
</style>

<script is:inline>
  const messages = [
    "Nirvee<br/>VISA & IMMIGRATION EXPERTS PVT LTD",
    "Your global education starts here—seamless and stress-free.",
    "Expert mentorship for every step of your path.",
    "Unlock Unrivaled Opportunities in Every Corner of the Globe."
  ];

  let currentIndex = 0;
  const titleElement = document.getElementById('hero-rotating-title');

  function rotateText() {
    if (!titleElement) return;

    // Fade out
    titleElement.style.opacity = '0';
    titleElement.style.transform = 'translateY(10px)';

    setTimeout(() => {
      currentIndex = (currentIndex + 1) % messages.length;
      titleElement.innerHTML = messages[currentIndex];
      
      // Fade in
      titleElement.style.opacity = '1';
      titleElement.style.transform = 'translateY(0)';
    }, 800); // Match transition duration
  }

  // Initial delay of 5 seconds before first rotation
  setInterval(rotateText, 5000);

  // Background Slideshow
  const slides = document.querySelectorAll('.hero-slideshow .slide');
  let currentSlide = 0;

  function nextSlide() {
    slides[currentSlide].classList.remove('active');
    currentSlide = (currentSlide + 1) % slides.length;
    slides[currentSlide].classList.add('active');
  }

  // Change slide every 5 seconds
  setInterval(nextSlide, 5000);
</script>
