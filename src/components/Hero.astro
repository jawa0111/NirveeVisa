---
interface Props {
  title: string;
  subtitle: string;
  ctaText: string;
  ctaLink: string;
}

const { title, subtitle, ctaText, ctaLink } = Astro.props;
---

<section id="hero-architectural" style="display: flex; height: 100vh; min-height: 800px; background-color: #ffffff; align-items: center; justify-content: center; position: relative; overflow: hidden; margin-top: -100px; padding-top: 100px; width: 100%;">
  
  <!-- BACKGROUND WAVE DESIGN -->
  <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; pointer-events: none;">
    <svg width="100%" height="100%" viewBox="0 0 1000 1000" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="mainCurveGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#FF758C;stop-opacity:1" />
          <stop offset="100%" style="stop-color:#7C3AED;stop-opacity:1" />
        </linearGradient>
      </defs>
      <!-- Main Swoosh -->
      <path d="M250,1000 Q550,850 450,450 T800,0 L1000,0 L1000,1000 Z" fill="url(#mainCurveGrad)" />
      <!-- Shadow/Depth Swoosh -->
      <path d="M0,1000 Q400,900 300,500 T650,0 L1000,0 L1000,1000 Z" fill="#6D28D9" fill-opacity="0.1" />
      <!-- Bottom Left Accent -->
      <path d="M0,1000 Q200,950 150,750 L0,700 Z" fill="#FF758C" fill-opacity="0.9" />
      <!-- Top Right Accent -->
      <circle cx="950" cy="50" r="180" fill="#ffffff" fill-opacity="0.3" />
    </svg>
  </div>

  <!-- CONTENT LAYER -->
  <div class="container" style="position: relative; z-index: 10; display: flex; justify-content: center; text-align: center; width: 100%;">
    <div style="max-width: 1100px;">
      
      <h1 
        id="hero-rotating-title"
        style="font-size: clamp(1.8rem, 4.5vw, 3.5rem); font-weight: 800; color: #1E1B4B; line-height: 1.1; letter-spacing: -1.2px; margin-bottom: 25px; text-shadow: 0 10px 30px rgba(0,0,0,0.05); font-family: 'Outfit', sans-serif; transition: opacity 0.8s ease, transform 0.8s ease;" 
        set:html={title} 
      />
      
      <p style="font-size: clamp(1.1rem, 3vw, 1.6rem); color: #4B5563; max-width: 750px; margin: 0 auto 50px; font-weight: 400; line-height: 1.5; font-family: 'Inter', sans-serif;">
        {subtitle}
      </p>
      
      <div style="display: flex; justify-content: center; gap: 20px;">
        <a href={ctaLink} style="padding: 18px 40px; background: linear-gradient(135deg, #7C3AED 0%, #DB2777 100%); color: white; border-radius: 50px; font-weight: 700; text-decoration: none; box-shadow: 0 10px 25px rgba(124, 58, 237, 0.3);">
          Consult With Us
        </a>
        <a href="/programs" style="padding: 18px 40px; border: 2px solid rgba(255, 255, 255, 0.5); color: #ffffff; border-radius: 50px; font-weight: 700; text-decoration: none;">
          Explore Programs
        </a>
      </div>
    </div>
  </div>

</section>

<style is:inline>
  /* Fallback and responsive styles that can't be inlined easily */
  @media (max-width: 768px) {
    #hero-architectural { 
      padding-top: 150px !important;
      height: auto !important;
      min-height: 100vh !important;
    }
    #hero-architectural .elite-actions {
      flex-direction: column !important;
    }
  }
</style>

<script is:inline>
  const messages = [
    "Nirvee Visa<br/>VISA & IMMIGRATION EXPERTS PVT LTD",
    "Your global education starts here—seamless and stress-free.",
    "Expert mentorship for every step of your path.",
    "Unlock Unrivaled Opportunities in Every Corner of the Globe."
  ];

  let currentIndex = 0;
  const titleElement = document.getElementById('hero-rotating-title');

  function rotateText() {
    if (!titleElement) return;

    // Fade out
    titleElement.style.opacity = '0';
    titleElement.style.transform = 'translateY(10px)';

    setTimeout(() => {
      currentIndex = (currentIndex + 1) % messages.length;
      titleElement.innerHTML = messages[currentIndex];
      
      // Fade in
      titleElement.style.opacity = '1';
      titleElement.style.transform = 'translateY(0)';
    }, 800); // Match transition duration
  }

  // Initial delay of 5 seconds before first rotation
  setInterval(rotateText, 5000);
</script>
