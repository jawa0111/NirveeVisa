---
---

<form class="contact-form" id="contactForm">
  <div class="form-row">
    <div class="form-group">
      <input type="text" id="name" name="name" required placeholder=" " />
      <label for="name">Full Name</label>
      <span class="error-message" id="nameError"></span>
    </div>
    <div class="form-group">
      <input type="email" id="email" name="email" required placeholder=" " />
      <label for="email">Email Address</label>
      <span class="error-message" id="emailError"></span>
    </div>
  </div>

  <div class="form-group">
    <input type="text" id="company" name="company" placeholder=" " />
    <label for="company">Company / Organization (Optional)</label>
  </div>

  <div class="form-group">
    <div class="custom-select" id="serviceDropdown">
      <div class="select-trigger">
        <span class="select-value">Select Service</span>
        <svg class="select-arrow" width="12" height="12" viewBox="0 0 292.4 292.4">
          <path fill="#7C3AED" d="M287 69.4a17.6 17.6 0 0 0-13-5.4H18.4c-5 0-9.3 1.8-12.9 5.4A17.6 17.6 0 0 0 0 82.2c0 5 1.8 9.3 5.4 12.9l128 127.9c3.6 3.6 7.8 5.4 12.8 5.4s9.2-1.8 12.8-5.4L287 95c3.5-3.5 5.4-7.8 5.4-12.8 0-5-1.9-9.2-5.5-12.8z"/>
        </svg>
      </div>
      <div class="select-options">
        <div class="select-option" data-value="corporate">Corporate Expansion</div>
        <div class="select-option" data-value="investor">Investor Visas</div>
        <div class="select-option" data-value="talent">Global Talent Visas</div>
        <div class="select-option" data-value="other">General Inquiry</div>
      </div>
      <input type="hidden" id="service" name="service" required>
    </div>
    <!-- <label for="service" class="select-label">Nature of Inquiry</label> -->
    <span class="error-message" id="serviceError"></span>
  </div>

  <div class="form-group">
    <textarea id="message" name="message" rows="5" required placeholder=" "></textarea>
    <label for="message">Detailed Message</label>
    <span class="error-message" id="messageError"></span>
  </div>

  <button type="submit" class="btn btn-primary w-full" id="submitBtn">
    <span class="btn-text">Request Private Consultation</span>
    <span class="btn-loading" style="display: none;">Sending...</span>
  </button>
</form>

<div id="formMessage" class="form-message" style="display: none;"></div>

<style>
  .contact-form {
    background: var(--white);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--card-border);
    padding: 48px;
    border-radius: 12px;
    box-shadow: var(--card-shadow);
  }

  .form-row {
    display: flex;
    gap: 24px;
    margin-bottom: 24px;
  }

  .form-row .form-group {
    margin-bottom: 0;
    flex: 1;
  }

  .form-group {
    position: relative;
    margin-bottom: 30px;
  }

  /* Floating Label Magic */
  input, select, textarea {
    width: 100%;
    padding: 16px 20px;
    background: var(--background);
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    font-family: inherit;
    font-size: 1rem;
    color: var(--text-main);
    transition: var(--transition);
  }

  textarea {
    resize: vertical;
    border-radius: 8px;
  }

  label {
    position: absolute;
    left: 20px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    transition: var(--transition);
    pointer-events: none;
    font-size: 0.95rem;
  }

  textarea + label {
    top: 20px;
    transform: none;
  }

  .select-label {
    top: 50%;
    transform: translateY(-50%);
  }

  /* When input is focused or has value (not placeholder shown) */
  input:focus ~ label,
  input:not(:placeholder-shown) ~ label,
  textarea:focus ~ label,
  textarea:not(:placeholder-shown) ~ label,
  select:focus ~ .select-label,
  select:valid ~ .select-label {
    top: -10px;
    left: 15px;
    font-size: 0.8rem;
    color: var(--primary-purple);
    background: var(--white);
    padding: 0 5px;
    border-radius: 3px;
  }

  input:focus, select:focus, textarea:focus {
    outline: none;
    border-color: var(--primary-purple);
    background: var(--white);
    box-shadow: 0 0 0 4px rgba(124, 58, 237, 0.05);
  }

  /* Custom Dropdown Styling */
  .custom-select {
    position: relative;
    width: 100%;
  }

  .select-trigger {
    width: 100%;
    padding: 16px 20px;
    background: var(--background);
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    font-family: inherit;
    font-size: 1rem;
    color: var(--text-main);
    transition: var(--transition);
    cursor: pointer;
    display: flex;
    justify-content: flex-end;
    align-items: center;
  }

  .select-trigger:hover {
    border-color: var(--primary-purple);
    background: var(--white);
  }

  .custom-select.active .select-trigger {
    border-color: var(--primary-purple);
    background: var(--white);
    box-shadow: 0 0 0 4px rgba(124, 58, 237, 0.05);
  }

  .select-value {
    flex: 1;
    color: var(--text-muted);
  }

  .custom-select.has-value .select-value {
    color: var(--text-main);
  }

  .select-arrow {
    transition: var(--transition);
    flex-shrink: 0;
  }

  .custom-select.active .select-arrow {
    transform: rotate(180deg);
  }

  .select-options {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--white);
    border: 1px solid var(--primary-purple);
    border-radius: 8px;
    box-shadow: var(--card-shadow);
    z-index: 10;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: var(--transition);
    margin-top: 4px;
    padding: 8px 0;
  }

  .custom-select.active .select-options {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .select-option {
    padding: 12px 16px;
    color: var(--text-main);
    cursor: pointer;
    transition: var(--transition);
    font-family: var(--font-body);
    font-size: 1rem;
  }

  .select-option:hover,
  .select-option.selected {
    background: var(--primary-gradient);
    color: var(--white);
  }

  .select-option:first-child {
    border-radius: 8px 8px 0 0;
  }

  .select-option:last-child {
    border-radius: 0 0 8px 8px;
  }

  .w-full {
    width: 100%;
    margin-top: 16px;
    padding: 18px;
  }

  .error-message {
    color: #e74c3c;
    font-size: 0.75rem;
    margin-top: 0.25rem;
    display: block;
    position: absolute;
    bottom: -20px;
    left: 0;
  }

  .form-message {
    margin-top: 1.5rem;
    padding: 1rem;
    border-radius: 8px;
    font-weight: 500;
  }

  .form-message.success {
    background: #d4edda;
    color: #155724;
    border: 1px solid #c3e6cb;
  }

  .form-message.error {
    background: #f8d7da;
    color: #721c24;
    border: 1px solid #f5c6cb;
  }

  .btn-loading {
    display: none;
  }

  @media (max-width: 768px) {
    .contact-form { padding: 30px 20px; }
    .form-row { flex-direction: column; gap: 30px; margin-bottom: 30px; }
  }
</style>

<script is:inline>
  (function() {
    const form = document.getElementById('contactForm');
    if (!form) return; // Exit if form not found

    const submitBtn = document.getElementById('submitBtn');
    const btnText = submitBtn.querySelector('.btn-text');
    const btnLoading = submitBtn.querySelector('.btn-loading');
    const formMessage = document.getElementById('formMessage');

    // Custom Dropdown Functionality
    const serviceDropdown = document.getElementById('serviceDropdown');
    if (!serviceDropdown) return;

    const selectTrigger = serviceDropdown.querySelector('.select-trigger');
    const selectValue = serviceDropdown.querySelector('.select-value');
    const selectOptions = serviceDropdown.querySelector('.select-options');
    const selectOptionElements = serviceDropdown.querySelectorAll('.select-option');
    const hiddenInput = serviceDropdown.querySelector('#service');

    // Toggle dropdown
    selectTrigger.addEventListener('click', function(e) {
      e.stopPropagation();
      serviceDropdown.classList.toggle('active');
    });

    // Handle option selection
    selectOptionElements.forEach(option => {
      option.addEventListener('click', function() {
        const value = this.getAttribute('data-value');
        const text = this.textContent;
        
        // Update hidden input
        hiddenInput.value = value;
        
        // Update display
        selectValue.textContent = text;
        
        // Update selected state
        selectOptionElements.forEach(opt => opt.classList.remove('selected'));
        this.classList.add('selected');
        
        // Close dropdown
        serviceDropdown.classList.remove('active');
        
        // Update label position
        if (value) {
          serviceDropdown.classList.add('has-value');
        }
      });
    });

    // Close dropdown when clicking outside
    document.addEventListener('click', function(e) {
      if (!serviceDropdown.contains(e.target)) {
        serviceDropdown.classList.remove('active');
      }
    });

    // Form validation
    function validateForm(formData) {
      const errors = {};

      // Name validation
      if (!formData.name.trim()) {
        errors.name = 'Name is required';
      } else if (formData.name.trim().length < 2) {
        errors.name = 'Name must be at least 2 characters';
      }

      // Email validation
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!formData.email.trim()) {
        errors.email = 'Email is required';
      } else if (!emailRegex.test(formData.email)) {
        errors.email = 'Please enter a valid email address';
      }

      // Service validation
      if (!formData.service || formData.service === '') {
        errors.service = 'Please select a service type';
      }

      // Message validation
      if (!formData.message.trim()) {
        errors.message = 'Message is required';
      } else if (formData.message.trim().length < 10) {
        errors.message = 'Message must be at least 10 characters';
      }

      return errors;
    }

    // Display validation errors
    function displayErrors(errors) {
      // Clear all previous errors
      document.querySelectorAll('.error-message').forEach(el => {
        el.textContent = '';
      });

      // Display new errors
      Object.keys(errors).forEach(field => {
        const errorElement = document.getElementById(field + 'Error');
        if (errorElement) {
          errorElement.textContent = errors[field];
        }
      });
    }

    // Show form message
    function showMessage(message, type) {
      formMessage.textContent = message;
      formMessage.className = `form-message ${type}`;
      formMessage.style.display = 'block';
      
      // Scroll to message
      formMessage.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    // Handle form submission
    form.addEventListener('submit', async function(e) {
      e.preventDefault();

      // Get form data
      const formData = {
        name: document.getElementById('name').value,
        email: document.getElementById('email').value,
        company: document.getElementById('company').value,
        service: document.getElementById('service').value,
        message: document.getElementById('message').value
      };

      // Validate form
      const errors = validateForm(formData);
      if (Object.keys(errors).length > 0) {
        displayErrors(errors);
        return;
      }

      // Clear any previous errors
      displayErrors({});

      // Show loading state
      submitBtn.disabled = true;
      btnText.style.display = 'none';
      btnLoading.style.display = 'inline';
      formMessage.style.display = 'none';

      try {
        // Send form data to API
        const response = await fetch('/api/send-email', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(formData)
        });

        const result = await response.json();

        if (response.ok && result.success) {
          // Success
          showMessage('✅ Your consultation request has been sent successfully! We\'ll get back to you soon.', 'success');
          form.reset();
        } else {
          // Error from API
          showMessage(`❌ ${result.error || 'Failed to send message. Please try again.'}`, 'error');
        }
      } catch (error) {
        console.error('Form submission error:', error);
        showMessage('❌ Network error. Please check your connection and try again.', 'error');
      } finally {
        // Reset button state
        submitBtn.disabled = false;
        btnText.style.display = 'inline';
        btnLoading.style.display = 'none';
      }
    });
  })();
</script>
