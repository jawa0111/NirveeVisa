---
interface Props {
  icon: string;
  title: string;
  description: string;
  link: string;
}

const { icon, title, description, link } = Astro.props;
---

<div class="glass-card service-card">
  <div class="icon-wrapper">
    <span>{icon}</span>
  </div>
  <h3>{title}</h3>
  <p>{description}</p>
  <a href={link} class="link-more">Learn More <span>&rarr;</span></a>
</div>

<style>
  .service-card {
    background: var(--card-bg);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    height: 100%;
    padding: 32px;
    border-radius: 16px;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
    border: 1px solid var(--card-border);
    box-shadow: var(--card-shadow);
  }

  .service-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.05), rgba(219, 39, 119, 0.05));
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: -1;
  }

  .service-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(124, 58, 237, 0.15);
    border-color: var(--primary-pink);
  }

  .service-card:hover::before {
    opacity: 1;
  }

  .icon-wrapper {
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.15), rgba(219, 39, 119, 0.1));
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    margin-bottom: 24px;
    font-size: 1.8rem;
    color: var(--primary-purple);
    border: 1px solid rgba(124, 58, 237, 0.1);
    transition: all 0.3s ease;
    position: relative;
  }

  .icon-wrapper::after {
    content: '';
    position: absolute;
    top: -2px;
    left: -2px;
    right: -2px;
    bottom: -2px;
    background: var(--primary-gradient);
    border-radius: 12px;
    opacity: 0;
    z-index: -1;
    transition: opacity 0.3s ease;
  }

  .service-card:hover .icon-wrapper {
    transform: scale(1.1) rotate(5deg);
    box-shadow: 0 8px 25px rgba(124, 58, 237, 0.25);
  }

  .service-card:hover .icon-wrapper::after {
    opacity: 1;
  }

  h3 {
    margin-bottom: 16px;
    font-size: 1.5rem;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  p {
    color: var(--text-muted);
    margin-bottom: 30px;
    font-size: 1rem;
    flex-grow: 1;
    transition: all 0.3s ease;
  }

  .service-card:hover h3 {
    color: var(--primary-purple);
    transform: translateX(4px);
  }

  .service-card:hover p {
    color: var(--text-main);
  }

  .link-more {
    font-family: var(--font-heading);
    font-weight: 500;
    color: var(--primary-purple);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: all 0.3s ease;
    position: relative;
  }

  .link-more::before {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--primary-gradient);
    transition: width 0.3s ease;
  }

  .link-more span {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: inline-block;
  }

  .service-card:hover .link-more {
    color: var(--primary-purple);
    transform: translateX(2px);
  }

  .service-card:hover .link-more::before {
    width: 100%;
  }

  .service-card:hover .link-more span {
    transform: translateX(8px);
    color: var(--primary-purple);
  }
</style>
