<style>
  .footer {
    background-color: var(--obsidian-light);
    color: var(--white);
    padding: 100px 0 30px;
    margin-top: 100px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.5fr;
    gap: 60px;
    margin-bottom: 80px;
  }

  .footer-info h3 {
    margin-bottom: 24px;
    font-size: 1.8rem;
    letter-spacing: 1px;
  }

  .footer-logo img {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    transition: all 0.3s ease;
    object-fit: cover;
  }

  .footer-logo img:hover {
    transform: scale(1.05);
    box-shadow: 0 8px 25px rgba(212, 175, 55, 0.3);
  }

  .footer-info p {
    color: var(--text-muted);
    font-size: 1rem;
    max-width: 300px;
  }

  .footer-links h4, .footer-contact h4 {
    color: var(--gold);
    margin-bottom: 30px;
    font-size: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .footer-links ul li {
    margin-bottom: 16px;
  }

  .footer-links ul li a {
    color: var(--text-muted);
    transition: var(--transition);
  }

  .footer-links ul li a:hover {
    color: var(--white);
    padding-left: 8px;
    border-left: 2px solid var(--gold);
  }

  .footer-contact p {
    color: var(--text-muted);
    margin-bottom: 16px;
  }

  .social-icons {
    display: flex;
    gap: 12px;
    margin-bottom: 20px;
  }

  .social-icons a {
    color: var(--white);
    opacity: 0.8;
    transition: var(--transition);
  }

  .social-icons a:hover {
    opacity: 1;
    transform: translateY(-2px);
  }

  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.05);
    padding-top: 30px;
  }

  .bottom-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .legal-links {
    display: flex;
    gap: 24px;
  }

  .legal-links a:hover {
    color: var(--gold);
  }

  .gold-text {
    color: var(--gold);
  }

  @media (max-width: 992px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 600px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
    .bottom-content {
      flex-direction: column;
      gap: 20px;
      text-align: center;
    }
  }
</style>
