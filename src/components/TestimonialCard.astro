---
interface Props {
  name: string;
  role: string;
  content: string;
  image?: string;
}

const { name, role, content, image = '👤' } = Astro.props;
---

<div class="glass-card testimonial-card">
  <div class="quote-icon">"</div>
  <p class="content">{content}</p>
  <div class="user-info">
    <div class="avatar">{image}</div>
    <div class="details">
      <h4>{name}</h4>
      <span class="gold-text">{role}</span>
    </div>
  </div>
</div>

<style>
  .testimonial-card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 40px;
    height: 100%;
  }

  .quote-icon {
    font-size: 5rem;
    color: var(--primary-purple);
    opacity: 0.1;
    position: absolute;
    top: 20px;
    right: 40px;
    font-family: serif;
    height: 40px;
    line-height: 1;
    user-select: none;
  }

  .content {
    font-style: italic;
    font-size: 1.15rem;
    line-height: 1.7;
    margin-bottom: 30px;
    position: relative;
    z-index: 1;
    flex-grow: 1;
  }

  .user-info {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: auto;
    border-top: 1px solid var(--border-light);
    padding-top: 20px;
  }

  .avatar {
    width: 48px;
    height: 48px;
    background: rgba(124, 58, 237, 0.1);
    border: 1px solid rgba(124, 58, 237, 0.2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
  }

  .details h4 {
    font-size: 1.05rem;
    margin-bottom: 4px;
    letter-spacing: 0.05em;
  }

  .details span {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 500;
  }
</style>
