---
const navLinks = [
  { name: 'Home', href: '/' },
  { name: 'Programs', href: '/programs' },
  { name: 'Services', href: '/services' },
  { name: 'Testimonials', href: '/testimonials' },
  { name: 'About Us', href: '/about' },
  { name: 'Contact Us', href: '/contact' }
];
---

<div class="top-bar">
  <div class="container top-bar-container">
    <div class="top-bar-left">
      <div class="social-icons">
        <a href="#" aria-label="Instagram"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg></a>
        <a href="#" aria-label="Facebook"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/></svg></a>
        <a href="#" aria-label="LinkedIn"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5c0 1.381-1.11 2.5-2.48 2.5s-2.48-1.119-2.48-2.5c0-1.38 1.11-2.5 2.48-2.5s2.48 1.12 2.48 2.5zm.02 4.5h-5v16h5v-16zm7.982 0h-4.968v16h4.969v-8.399c0-4.67 6.029-5.052 6.029 0v8.399h4.988v-10.131c0-7.88-8.922-7.593-11.018-3.714v-2.155z"/></svg></a>
      </div>
    </div>
    <div class="top-bar-right">
      <a href="mailto:marketing@platinumconsultancies.com" class="top-bar-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.103 0-2 .897-2 2v12c0 1.103.897 2 2 2h16c1.103 0 2-.897 2-2V6c0-1.103-.897-2-2-2zm0 2v.511l-8 6.223-8-6.222V6h16zM4 18V9.722l7.385 5.745a.994.994 0 0 0 1.23 0L20 9.722V18H4z"></path></svg>
        marketing@platinumconsultancies.com
      </a>
      <span class="top-bar-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"></path></svg>
        No.6/2, Unity Place, Colombo 03
      </span>
      <a href="tel:+94704932634" class="top-bar-phone">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.47.57 3.57.11.35.03.74-.25 1.02L6.62 10.79z"/></svg>
        +94 704 932 634
      </a>
    </div>
  </div>
</div>

<header class="header">
  <div class="container nav-container">
    <div class="logo-container">
      <div class="logo">
        <a href="/">Nirvee <span class="accent-text">Visa</span></a>
      </div>
      <div class="logo-sub">
        <span class="gold-text">VISA & IMMIGRATION EXPERTS PVT LTD</span>
      </div>
    </div>

    <nav class="nav">
      <ul class="nav-list">
        {navLinks.map(link => (
          <li key={link.name}>
            <a href={link.href} class="nav-link">{link.name}</a>
          </li>
        ))}
      </ul>
      <a href="/contact" class="btn btn-primary btn-sm">Start Journey</a>
    </nav>

    <div class="mobile-menu-btn">
      <span></span>
      <span></span>
      <span></span>
    </div>
  </div>
</header>

<style>
  /* Top Bar Styles */
  .top-bar {
    background-color: var(--white);
    border-bottom: 1px solid var(--border-light);
    padding: 10px 0;
    position: relative;
    z-index: 1001;
  }

  .top-bar-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .top-bar-left {
    display: flex;
    align-items: center;
  }

  .top-bar-right {
    display: flex;
    gap: 20px;
    align-items: center;
  }

  .social-icons {
    display: flex;
    gap: 15px;
  }

  .top-bar-link {
    color: var(--text-main);
    text-decoration: none;
    font-size: 0.8rem;
    display: flex;
    align-items: center;
    gap: 6px;
    opacity: 0.8;
    transition: 0.3s;
  }

  .top-bar-link:hover {
    color: var(--primary-purple);
  }

  .social-icons a {
    color: var(--text-muted);
    transition: 0.3s;
    opacity: 0.9;
  }

  .social-icons a:hover {
    color: var(--primary-purple);
    transform: translateY(-1px);
  }

  .top-bar-phone {
    color: var(--primary-purple);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 6px;
    opacity: 0.9;
    transition: 0.3s;
  }

  .top-bar-phone:hover {
    opacity: 1;
    color: var(--primary-pink);
  }

  /* Core Styles */
  .header {
    background: rgba(255, 255, 255, 0.8);
    padding: 16px 0;
    position: sticky;
    top: 0;
    z-index: 1000;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border-light);
  }

  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  /* Logo Styling - Forces Gold Color */
  .logo-container {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .logo a {
    color: var(--text-main);
    font-size: 1.8rem;
    font-weight: 800;
    letter-spacing: -0.5px;
    text-decoration: none;
  }

  .accent-text {
    color: var(--primary-pink);
  }

  .logo-sub {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 1px;
    margin-top: 2px;
    opacity: 0.8;
  }

  .btn-sm {
    padding: 10px 24px;
    font-size: 0.85rem;
  }

  /* Navigation */
  .nav {
    display: flex;
    align-items: center;
    gap: 40px;
  }

  .nav-list {
    display: flex;
    gap: 28px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    color: var(--text-main);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: 0.3s ease;
  }

  .nav-link:hover {
    color: var(--primary-purple);
  }


  /* Mobile */
  @media (max-width: 992px) {
    .top-bar {
      display: none;
    }
    
    .nav {
      display: none;
    }
    .mobile-menu-btn {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .mobile-menu-btn span {
      width: 28px;
      height: 2px;
      background-color: var(--text-main);
    }
  }

  @media (max-width: 768px) {
    .top-bar-container {
      flex-direction: column;
      gap: 8px;
    }
    
    .top-bar-info {
      flex-direction: column;
      gap: 8px;
      align-items: center;
    }
  }
</style>