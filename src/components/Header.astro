---
const navLinks = [
  { name: 'Home', href: '/' },
  { 
    name: 'Programs', 
    href: '#',
    dropdown: [
      {
        name: 'PR Pathway',
        href: '#',
        submenu: [
          { name: 'Canada PR', href: '/programs/canada-pr' },
          { name: 'Australia PR', href: '/programs/australia-pr' },
          { name: 'New Zealand PR', href: '/programs/new-zealand-pr' },
          { name: 'UK Settlement Visa', href: '/programs/uk-settlement' }
        ]
      },
      { 
        name: 'Study Permit', 
        href: '#',
        submenu: [
          { name: 'Canada Student Visa', href: '/programs/canada-student-visa' },
          { name: 'Ireland Student Visa', href: '/programs/ireland-student-visa' },
          { name: 'Germany Student Visa', href: '/programs/germany-student-visa' },
          { name: 'UK Student Visa', href: '/programs/uk-student-visa' },
          { name: 'Netherlands Student Visa', href: '/programs/netherlands-student-visa' },
          { name: 'New Zealand Student Visa', href: '/programs/new-zealand-student-visa' },
          { name: 'Sweden Student Visa', href: '/programs/sweden-student-visa' }
        ]
      },
      {
        name: 'Job Seeker Visa',
        href: '#',
        submenu: [
          { name: 'Germany Job Seeker Visa', href: '/programs/germany-job-seeker-visa' },
          { name: 'Austria Job Seeker Visa', href: '/programs/austria-job-seeker-visa' },
          { name: 'Portugal Job Seeker Visa', href: '/programs/portugal-job-seeker-visa' },
          { name: 'UAE Job Seeker Visa', href: '/programs/uae-job-seeker-visa' }
        ]
      },
      { name: 'New Programs', href: '/programs/new-programs' }
    ]
  },
  { name: 'Services', href: '/services' },
  { name: 'Testimonials', href: '/testimonials' },
  { name: 'About Us', href: '/about' },
  { name: 'Contact Us', href: '/contact' }
];
---

<div class="top-bar">
  <div class="container top-bar-container">
    <div class="top-bar-left">
      <div class="social-icons">
        <a href="#" aria-label="Instagram"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg></a>
        <a href="https://www.facebook.com/profile.php?id=61586937637733" target="_blank" aria-label="Facebook"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/></svg></a>
        <a href="#" aria-label="LinkedIn"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5c0 1.381-1.11 2.5-2.48 2.5s-2.48-1.119-2.48-2.5c0-1.38 1.11-2.5 2.48-2.5s2.48 1.12 2.48 2.5zm.02 4.5h-5v16h5v-16zm7.982 0h-4.968v16h4.969v-8.399c0-4.67 6.029-5.052 6.029 0v8.399h4.988v-10.131c0-7.88-8.922-7.593-11.018-3.714v-2.155z"/></svg></a>
      </div>
    </div>
    <div class="top-bar-right">
      <a href="mailto:nirveevisaimmigirationexperts@gmail.com" class="top-bar-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.103 0-2 .897-2 2v12c0 1.103.897 2 2 2h16c1.103 0 2-.897 2-2V6c0-1.103-.897-2-2-2zm0 2v.511l-8 6.223-8-6.222V6h16zM4 18V9.722l7.385 5.745a.994.994 0 0 0 1.23 0L20 9.722V18H4z"></path></svg>
        nirveevisaimmigirationexperts@gmail.com
      </a>
      <span class="top-bar-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"></path></svg>
        No 131, Adiyapatham Road, Kokuvil East, Jaffna
      </span>
      <a href="tel:+4917674966603" class="top-bar-phone">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.47.57 3.57.11.35.03.74-.25 1.02L6.62 10.79z"/></svg>
        +49 176 74966603
      </a>
    </div>
  </div>
</div>

<header class="header">
  <div class="container nav-container">
    <div class="logo-container">
      <div class="logo-wrapper">
        <div class="logo-icon">
          <img src="/logo.png" alt="Nirvee Visa Immigration Experts Logo" width="55" height="55" />
        </div>
        <div class="logo-text">
          <div class="logo">
            <a href="/"><span class="logo-blue">Nirvee</span> </a>
          </div>
          <div class="logo-sub">
            VISA & IMMIGRATION EXPERTS PVT LTD
          </div>
        </div>
      </div>
    </div>

    <nav class="nav">
      <ul class="nav-list">
        {navLinks.map(link => (
          <li key={link.name} class="nav-item">
            {link.dropdown ? (
              <>
                {link.href === '#' ? (
                  <span class="nav-link dropdown-toggle" style="cursor: default;">{link.name}</span>
                ) : (
                  <a href={link.href} class="nav-link dropdown-toggle">{link.name}</a>
                )}
                <ul class="dropdown-menu">
                  {link.dropdown.map(item => (
                    <li key={item.name} class={item.submenu ? 'has-submenu' : ''}>
                      {item.href === '#' ? (
                        <span class="dropdown-link" style="cursor: default;">
                          {item.name}
                          {item.submenu && (
                            <svg class="submenu-arrow" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                              <path d="M9.29 6.71c-.39.39-.39 1.02 0 1.41L13.17 12l-3.88 3.88c-.39.39-.39 1.02 0 1.41.39.39 1.02.39 1.41 0l4.59-4.59c.39-.39.39-1.02 0-1.41L10.7 6.71c-.38-.39-1.01-.39-1.4 0z"/>
                            </svg>
                          )}
                        </span>
                      ) : (
                        <a href={item.href} class="dropdown-link">
                          {item.name}
                          {item.submenu && (
                            <svg class="submenu-arrow" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                              <path d="M9.29 6.71c-.39.39-.39 1.02 0 1.41L13.17 12l-3.88 3.88c-.39.39-.39 1.02 0 1.41.39.39 1.02.39 1.41 0l4.59-4.59c.39-.39.39-1.02 0-1.41L10.7 6.71c-.38-.39-1.01-.39-1.4 0z"/>
                            </svg>
                          )}
                        </a>
                      )}
                      {item.submenu && (
                        <ul class="submenu">
                          {item.submenu.map(subitem => (
                            <li key={subitem.name}>
                              <a href={subitem.href} class="submenu-link">{subitem.name}</a>
                            </li>
                          ))}
                        </ul>
                      )}
                    </li>
                  ))}
                </ul>
              </>
            ) : (
              <a href={link.href} class="nav-link">{link.name}</a>
            )}
          </li>
        ))}
      </ul>
      <a href="/contact" class="btn btn-primary btn-sm">Start Journey</a>
    </nav>

    <div class="mobile-menu-btn" id="mobileMenuBtn">
      <span></span>
      <span></span>
      <span></span>
    </div>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div class="mobile-menu-overlay" id="mobileMenuOverlay">
  <div class="mobile-menu">
    <div class="mobile-menu-header">
      <div class="logo-wrapper">
        <div class="logo-icon">
          <img src="/logo.png" alt="Nirvee Visa Immigration Experts Logo" width="40" height="40" />
        </div>
        <div class="logo-text">
          <div class="mobile-logo">
            <span class="logo-blue">Nirvee</span> 
          </div>
        </div>
      </div>
      <button class="mobile-menu-close" id="mobileMenuClose" aria-label="Close menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>
    <nav class="mobile-nav">
      <ul class="mobile-nav-list">
        <li><a href="/" class="mobile-nav-link">Home</a></li>
        <li class="mobile-dropdown">
          <button class="mobile-nav-link mobile-dropdown-toggle" aria-expanded="false">
            Programs
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M7 10l5 5 5-5z"/></svg>
          </button>
          <ul class="mobile-submenu">
            <li class="mobile-submenu-category">
              <span class="mobile-submenu-title">PR Pathway</span>
              <ul class="mobile-submenu-items">
                <li><a href="/programs/canada-pr">Canada PR</a></li>
                <li><a href="/programs/australia-pr">Australia PR</a></li>
                <li><a href="/programs/new-zealand-pr">New Zealand PR</a></li>
                <li><a href="/programs/uk-settlement">UK Settlement Visa</a></li>
              </ul>
            </li>
            <li class="mobile-submenu-category">
              <span class="mobile-submenu-title">Study Permit</span>
              <ul class="mobile-submenu-items">
                <li><a href="/programs/canada-student-visa">Canada Student Visa</a></li>
                <li><a href="/programs/ireland-student-visa">Ireland Student Visa</a></li>
                <li><a href="/programs/germany-student-visa">Germany Student Visa</a></li>
                <li><a href="/programs/uk-student-visa">UK Student Visa</a></li>
                <li><a href="/programs/netherlands-student-visa">Netherlands Student Visa</a></li>
                <li><a href="/programs/new-zealand-student-visa">New Zealand Student Visa</a></li>
                <li><a href="/programs/sweden-student-visa">Sweden Student Visa</a></li>
              </ul>
            </li>
            <li class="mobile-submenu-category">
              <span class="mobile-submenu-title">Job Seeker Visa</span>
              <ul class="mobile-submenu-items">
                <li><a href="/programs/germany-job-seeker-visa">Germany Job Seeker Visa</a></li>
                <li><a href="/programs/austria-job-seeker-visa">Austria Job Seeker Visa</a></li>
                <li><a href="/programs/portugal-job-seeker-visa">Portugal Job Seeker Visa</a></li>
                <li><a href="/programs/uae-job-seeker-visa">UAE Job Seeker Visa</a></li>
              </ul>
            </li>
            <li class="mobile-submenu-category">
              <a href="/programs/new-programs" class="mobile-submenu-title-link">New Programs</a>
            </li>
          </ul>
        </li>
        <li><a href="/services" class="mobile-nav-link">Services</a></li>
        <li><a href="/testimonials" class="mobile-nav-link">Testimonials</a></li>
        <li><a href="/about" class="mobile-nav-link">About Us</a></li>
        <li><a href="/contact" class="mobile-nav-link">Contact Us</a></li>
      </ul>
      <a href="/contact" class="btn btn-primary mobile-cta">Start Your Journey</a>
    </nav>
  </div>
</div>

<style>
  /* Top Bar Styles */
  .top-bar {
    background-color: var(--white);
    border-bottom: 1px solid var(--border-light);
    padding: 10px 0;
    position: relative;
    z-index: 1001;
  }

  .top-bar-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .top-bar-left {
    display: flex;
    align-items: center;
  }

  .top-bar-right {
    display: flex;
    gap: 20px;
    align-items: center;
  }

  .social-icons {
    display: flex;
    gap: 15px;
  }

  .top-bar-link {
    color: var(--text-main);
    text-decoration: none;
    font-size: 0.8rem;
    display: flex;
    align-items: center;
    gap: 6px;
    opacity: 0.8;
    transition: 0.3s;
  }

  .top-bar-link:hover {
    color: var(--primary-purple);
  }

  .social-icons a {
    color: var(--text-muted);
    transition: 0.3s;
    opacity: 0.9;
  }

  .social-icons a:hover {
    color: var(--primary-purple);
    transform: translateY(-1px);
  }

  .top-bar-phone {
    color: var(--primary-purple);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 6px;
    opacity: 0.9;
    transition: 0.3s;
  }

  .top-bar-phone:hover {
    opacity: 1;
    color: var(--primary-pink);
  }

  /* Core Styles */
  .header {
    background: rgba(255, 255, 255, 0.8);
    padding: 16px 0;
    position: sticky;
    top: 0;
    z-index: 1000;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border-light);
  }

  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  /* Logo Styling - Forces Gold Color */
  .logo-container {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .logo-wrapper {
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .logo-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .logo a {
    color: var(--text-main);
    font-size: 1.8rem;
    font-weight: 800;
    letter-spacing: -0.5px;
    text-decoration: none;
  }

  .logo-blue {
    color: #08328f; /* Blue color */
    font-size: 2.2rem;
  }

  .logo-accent {
    color: #f1c73d; /* Authentic Gold from branding */
  }

  .logo-sub {
    color: #f1c73d; /* Navy from branding background */
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 1px;
    margin-top: 2px;
    opacity: 0.9;
    text-transform: uppercase;
  }

  .btn-sm {
    padding: 10px 24px;
    font-size: 0.85rem;
  }

  /* Navigation */
  .nav {
    display: flex;
    align-items: center;
    gap: 40px;
  }

  .nav-list {
    display: flex;
    gap: 28px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    color: var(--text-main);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: 0.3s ease;
  }

  .nav-link:hover {
    color: var(--primary-purple);
  }

  /* Dropdown Styles */
  .nav-item {
    position: relative;
  }

  .dropdown-toggle {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .dropdown-toggle::after {
    content: '';
    font-size: 0;
  }

  .nav-item:hover .dropdown-toggle::after {
    transform: none;
  }

  .dropdown-menu {
    position: absolute;
    top: 100%;
    left: 0;
    background: white;
    min-width: 200px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    border-radius: 8px;
    border: 1px solid var(--border-light);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: all 0.3s ease;
    z-index: 1000;
    padding: 8px 0;
    margin-top: 8px;
  }

  .nav-item:hover .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 10px 20px;
    color: var(--text-main);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 400;
    transition: all 0.3s ease;
    border: none;
    background: none;
    width: 100%;
    text-align: left;
  }

  .dropdown-link:hover {
    color: var(--primary-purple);
    background: rgba(124, 58, 237, 0.05);
  }

  .submenu-arrow {
    width: 16px;
    height: 16px;
    color: var(--text-muted);
    transition: all 0.3s ease;
    flex-shrink: 0;
    margin-left: 8px;
  }

  /* Submenu/Mega Menu Styles */
  .has-submenu {
    position: relative;
  }

  .has-submenu > .dropdown-link {
    position: relative;
  }

  .submenu {
    position: absolute;
    top: 0;
    left: 100%;
    background: white;
    min-width: 240px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
    border-radius: 8px;
    border: 1px solid var(--border-light);
    opacity: 0;
    visibility: hidden;
    transform: translateX(-10px);
    transition: all 0.2s ease;
    z-index: 1001;
    padding: 8px 0;
    margin-left: 2px;
    list-style: none;
    display: block;
  }

  .has-submenu:hover > .submenu {
    opacity: 1;
    visibility: visible;
    transform: translateX(0);
  }

  .has-submenu:hover .submenu-arrow {
    color: var(--primary-purple);
    transform: rotate(180deg);
  }

  .has-submenu:hover > .dropdown-link {
    color: var(--primary-purple);
    background: rgba(124, 58, 237, 0.05);
  }

  .submenu li {
    display: block;
    width: 100%;
  }

  .submenu-link {
    display: block;
    padding: 12px 20px;
    color: var(--text-main);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 400;
    transition: all 0.3s ease;
    border: none;
    background: none;
    width: 100%;
    text-align: left;
    border-bottom: 1px solid var(--border-light);
    white-space: nowrap;
  }

  .submenu li:last-child .submenu-link {
    border-bottom: none;
  }

  .submenu-link:hover {
    color: var(--primary-purple);
    background: rgba(124, 58, 237, 0.05);
  }

  /* Active/Current indicator - red minus sign */
  .has-submenu > .dropdown-link::before {
    content: '−';
    position: absolute;
    left: 8px;
    top: 50%;
    transform: translateY(-50%);
    color: #dc2626;
    font-weight: bold;
    font-size: 1.2rem;
    opacity: 0;
    transition: all 0.3s ease;
  }

  .has-submenu:hover > .dropdown-link::before {
    opacity: 1;
  }

  .has-submenu:hover > .dropdown-link {
    color: #dc2626;
    padding-left: 24px;
  }

  /* Mobile */
  @media (max-width: 992px) {
    .top-bar {
      display: none;
    }
    
    .nav {
      display: none;
    }
    
    .nav-container {
      padding: 0 10px;
    }
    
    .mobile-menu-btn {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-right: -8px;
    }
    .mobile-menu-btn span {
      width: 28px;
      height: 2px;
      background-color: var(--text-main);
    }
  }

  @media (max-width: 768px) {
    .top-bar-container {
      flex-direction: column;
      gap: 8px;
    }
    
    .top-bar-info {
      flex-direction: column;
      gap: 8px;
      align-items: center;
    }
  }

  /* Mobile Menu Styles */
  .mobile-menu-btn {
    display: none; /* Hidden by default on desktop */
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 12px;
    margin: -4px;
    z-index: 9999;
    background: transparent;
    border: none;
    position: relative;
    min-width: 44px;
    min-height: 44px;
    align-items: center;
    justify-content: center;
  }

  /* Show mobile menu button on tablet and below */
  @media (max-width: 992px) {
    .mobile-menu-btn {
      display: flex !important;
    }
  }

  .mobile-menu-btn span {
    width: 25px;
    height: 3px;
    background-color: var(--text-main);
    transition: all 0.3s ease;
    border-radius: 2px;
    pointer-events: none;
  }

  .mobile-menu-btn.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .mobile-menu-btn.active span:nth-child(2) {
    opacity: 0;
  }

  .mobile-menu-btn.active span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  .mobile-menu-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    z-index: 2000;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }

  .mobile-menu-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  .mobile-menu {
    position: fixed;
    top: 0;
    right: -100%;
    width: 85%;
    max-width: 360px;
    height: 100%;
    background: var(--white);
    z-index: 2001;
    transition: right 0.3s ease;
    overflow-y: auto;
    box-shadow: -5px 0 30px rgba(0, 0, 0, 0.2);
  }

  .mobile-menu-overlay.active .mobile-menu {
    right: 0;
  }

  .mobile-menu-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px;
    border-bottom: 1px solid var(--border-light);
    background: linear-gradient(135deg, #f3e8ff 0%, #e9d5ff 100%);
  }

  .mobile-menu-close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: var(--text-main);
    transition: all 0.3s ease;
    border-radius: 8px;
  }

  .mobile-menu-close:hover {
    background: rgba(124, 58, 237, 0.1);
  }

  .mobile-logo {
    font-size: 1.4rem;
    font-weight: 800;
  }

  .mobile-nav {
    padding: 20px;
  }

  .mobile-nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .mobile-nav-list > li {
    border-bottom: 1px solid var(--border-light);
  }

  .mobile-nav-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 0;
    color: var(--text-main);
    font-weight: 600;
    font-size: 1.1rem;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .mobile-nav-link:hover {
    color: var(--primary-purple);
  }

  .mobile-dropdown-toggle {
    width: 100%;
    background: none;
    border: none;
    font-family: inherit;
    cursor: pointer;
  }

  .mobile-dropdown-toggle svg {
    transition: transform 0.3s ease;
  }

  .mobile-dropdown.open .mobile-dropdown-toggle svg {
    transform: rotate(180deg);
  }

  .mobile-submenu {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
    list-style: none;
    padding: 0 0 0 16px;
  }

  .mobile-dropdown.open .mobile-submenu {
    max-height: 800px;
  }

  .mobile-submenu-category {
    padding: 8px 0;
  }

  .mobile-submenu-title {
    display: block;
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--primary-purple);
    padding: 8px 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .mobile-submenu-title-link {
    display: block;
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--primary-purple);
    padding: 8px 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
  }

  .mobile-submenu-items {
    list-style: none;
    padding: 0 0 0 12px;
  }

  .mobile-submenu-items li {
    padding: 4px 0;
  }

  .mobile-submenu-items a {
    display: block;
    padding: 8px 0;
    color: var(--text-muted);
    font-size: 0.95rem;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .mobile-submenu-items a:hover {
    color: var(--primary-purple);
    padding-left: 8px;
  }

  .mobile-cta {
    display: block;
    margin-top: 24px;
    text-align: center;
    padding: 16px 24px;
    font-size: 1rem;
  }

  body.menu-open {
    overflow: hidden;
  }
</style>

<script is:inline>
  // Use a flag to track if menu is initialized
  if (!window.mobileMenuInitialized) {
    window.mobileMenuInitialized = true;
    
    function openMenu() {
      const overlay = document.getElementById('mobileMenuOverlay');
      const btn = document.getElementById('mobileMenuBtn');
      if (overlay) overlay.classList.add('active');
      if (btn) btn.classList.add('active');
      document.body.classList.add('menu-open');
    }

    function closeMenu() {
      const overlay = document.getElementById('mobileMenuOverlay');
      const btn = document.getElementById('mobileMenuBtn');
      if (overlay) overlay.classList.remove('active');
      if (btn) btn.classList.remove('active');
      document.body.classList.remove('menu-open');
      // Close all dropdowns
      document.querySelectorAll('.mobile-dropdown').forEach(d => d.classList.remove('open'));
    }

    // Event delegation for the entire document
    document.addEventListener('click', function(e) {
      const btn = e.target.closest('#mobileMenuBtn');
      const overlay = e.target.closest('#mobileMenuOverlay');
      const closeBtn = e.target.closest('#mobileMenuClose');
      const link = e.target.closest('.mobile-nav a, .mobile-submenu a, .mobile-submenu-title-link');
      const dropdownToggle = e.target.closest('.mobile-dropdown-toggle');
      
      if (btn) {
        e.preventDefault();
        const o = document.getElementById('mobileMenuOverlay');
        if (o && o.classList.contains('active')) {
          closeMenu();
        } else {
          openMenu();
        }
      }
      
      if (closeBtn) {
        e.preventDefault();
        closeMenu();
      }
      
      if (link) {
        closeMenu();
      }
      
      if (dropdownToggle) {
        e.preventDefault();
        e.stopPropagation();
        const parent = dropdownToggle.parentElement;
        const isOpen = parent.classList.contains('open');
        
        // Close all dropdowns
        document.querySelectorAll('.mobile-dropdown').forEach(d => {
          d.classList.remove('open');
          const b = d.querySelector('.mobile-dropdown-toggle');
          if (b) b.setAttribute('aria-expanded', 'false');
        });
        
        // Open this one if it was closed
        if (!isOpen) {
          parent.classList.add('open');
          dropdownToggle.setAttribute('aria-expanded', 'true');
        }
      }
      
      // Close when clicking overlay background
      if (e.target.id === 'mobileMenuOverlay') {
        closeMenu();
      }
    });

    // Escape key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        const overlay = document.getElementById('mobileMenuOverlay');
        if (overlay && overlay.classList.contains('active')) {
          closeMenu();
        }
      }
    });
  }
</script>